@page "/login"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@inject AccountingService AccService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; background-color: #f0f2f5; display: flex; justify-content: center; align-items: center;">

    <div class="card shadow-lg p-4 border-0" style="width: 100%; max-width: 400px; border-radius: 15px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">⛪ 교회학교 회계 시스템</h2>
            <p class="text-muted">서비스 이용을 위해 로그인해주세요</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">아이디</label>
            <input type="text" class="form-control form-control-lg" @bind="Username" @onkeyup="EnterKey" placeholder="admin" />
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold">비밀번호</label>
            <input type="password" class="form-control form-control-lg" @bind="Password" @onkeyup="EnterKey" placeholder="1234" />
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger p-2 text-center small mb-3">@ErrorMessage</div>
        }

        <button type="button" class="btn btn-primary w-100 btn-lg fw-bold" @onclick="TryLogin">
            @if (isLoading)
            {
                <span>🔄 확인 중...</span>
            }
            else
            {

                <span>로그인</span>
            }
        </button>

        <div class="text-center mt-3">
            <small class="text-muted">기본 계정: admin / 1234</small>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<User> OnLoginSuccess { get; set; }

    private string Username = "";
    private string Password = "";
    private string ErrorMessage = "";
    private bool isLoading = false;

    // 페이지 로드 시 계정 점검
    protected override async Task OnInitializedAsync()
    {
        await AccService.EnsureDefaultUsersAsync();
    }

    private async Task TryLogin()
    {
        isLoading = true;
        ErrorMessage = "";

        var users = await AccService.GetAllUsersAsync();

        // 안전장치: 사용자 없으면 생성 후 다시 조회
        if (users.Count == 0)
        {
            await AccService.EnsureDefaultUsersAsync();
            users = await AccService.GetAllUsersAsync();
        }

        var user = users.FirstOrDefault(u => u.Username == Username && u.Password == Password);

        if (user != null)
        {
            // ★★★ 핵심 수정: Nav.NavigateTo(...) 코드가 절대 있으면 안 됩니다!
            // 오직 부모에게 신호만 보냅니다.
            await OnLoginSuccess.InvokeAsync(user);
        }
        else
        {
            ErrorMessage = "아이디 또는 비밀번호가 틀렸습니다.";
        }

        isLoading = false;
    }

    private async Task EnterKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await TryLogin();
    }
}