@page "/"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@inject AccountingService AccService

<div class="container-fluid mt-4">
    @* 상단 헤더: 제목 및 필터 *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <h2 class="fw-bold text-primary mb-0">
                @TargetYear 년도 @(SelectedDepartment == "전체(통합)" ? "전체 부서 통합" : SelectedDepartment) 예산 현황
            </h2>
            @if (currentUser?.Role == "Admin")
            {
                <select class="form-select w-auto border-danger fw-bold shadow-sm" @onchange="OnDepartmentChange">
                    <option value="전체(통합)" selected="@(SelectedDepartment == "전체(통합)")">전체(통합)</option>
                    @foreach (var dept in Departments)
                    {
                        <option value="@dept" selected="@(dept == SelectedDepartment)">@dept</option>
                    }
                </select>
            }
        </div>
        <select class="form-select w-auto border-primary shadow-sm" @bind="TargetYear">
            @for (int y = 2025; y <= 2028; y++)
            {
                <option value="@y">@y 년</option>
            }
        </select>
    </div>

    @* ================================================================================= *@
    @* 1. [Admin] 전체(통합) 뷰: 부서별 비교 테이블 *@
    @* ================================================================================= *@
    @if (SelectedDepartment == "전체(통합)")
    {
        <div class="table-responsive shadow-sm rounded mb-4">
            <table class="table table-bordered text-center align-middle bg-white mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="py-3">구분</th>
                        @foreach (var d in integratedStats)
                        {
                            <th>@d.ShortName</th>
                        }
                        <th class="bg-primary text-white">합계</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold bg-light">예산액</td>
                        @foreach (var d in integratedStats)
                        {
                            <td class="text-end">@d.Budget.ToString("N0")</td>
                        }
                        <td class="text-end fw-bold text-primary bg-light">@integratedStats.Sum(x => x.Budget).ToString("N0")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light">집행액</td>
                        @foreach (var d in integratedStats)
                        {
                            <td class="text-end text-danger">@d.Spent.ToString("N0")</td>
                        }
                        <td class="text-end fw-bold text-danger bg-light">@integratedStats.Sum(x => x.Spent).ToString("N0")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light">잔액</td>
                        @foreach (var d in integratedStats)
                        {
                            <td class="text-end text-success">@d.Balance.ToString("N0")</td>
                        }
                        <td class="text-end fw-bold text-success bg-light">@integratedStats.Sum(x => x.Balance).ToString("N0")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light">집행률</td>
                        @foreach (var d in integratedStats)
                        {
                            <td>
                                <span class="badge @(d.Rate > 90 ? "bg-danger" : "bg-secondary")">@d.Rate%</span>
                            </td>
                        }
                        <td class="bg-light">
                            @{
                                var totalB = integratedStats.Sum(x => x.Budget);
                                var totalS = integratedStats.Sum(x => x.Spent);
                                var totalR = totalB == 0 ? 0 : (int)(totalS / totalB * 100);
                            }
                            <span class="badge bg-dark">@totalR%</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    }

    @* ================================================================================= *@
    @* 2. [User/Admin] 개별 부서 뷰: 상세 통계 및 차트 *@
    @* ================================================================================= *@
    else
    {
        @* 요약 카드 *@
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-primary text-white text-center p-3 h-100">
                    <small class="opacity-75">총 예산</small>
                    <h3 class="fw-bold mb-0">@totalBudget.ToString("N0")원</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-danger text-white text-center p-3 h-100">
                    <small class="opacity-75">현재 지출</small>
                    <h3 class="fw-bold mb-0">@totalSpent.ToString("N0")원</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-success text-white text-center p-3 h-100">
                    <small class="opacity-75">현재 잔액</small>
                    <h3 class="fw-bold mb-0">@((totalBudget - totalSpent).ToString("N0"))원</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-secondary text-white text-center p-3 h-100">
                    <small class="opacity-75">전체 집행률</small>
                    <h3 class="fw-bold mb-0">@(totalBudget == 0 ? 0 : (int)(totalSpent / totalBudget * 100))%</h3>
                </div>
            </div>
        </div>

        <div class="row">
            @* 지출 상세 테이블 *@
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-top-danger">
                    <div class="card-header bg-white fw-bold py-3"><i class="bi bi-dash-circle text-danger me-2"></i>📤 지출 예산 대비 집행 현황</div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0 align-middle text-center">
                            <thead class="table-light">
                                <tr><th>항목</th><th>예산액</th><th>집행액</th><th>잔액</th><th>비율</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var item in budgetStats)
                                {
                                    var rate = item.Budget == 0 ? 0 : (int)(item.Spent / item.Budget * 100);
                                    <tr class="@(item.Category.Contains("미분류") ? "table-warning" : "")">
                                        <td class="fw-bold text-start ps-4">@item.Category</td>
                                        <td class="text-end pe-3">@item.Budget.ToString("N0")</td>
                                        <td class="text-end pe-3 text-danger fw-bold">@item.Spent.ToString("N0")</td>
                                        <td class="text-end pe-3">@((item.Budget - item.Spent).ToString("N0"))</td>
                                        <td>
                                            @if (item.Budget > 0)
                                            {
                                                <div class="progress" style="height: 6px; width: 60px; margin: 0 auto;">
                                                    <div class="progress-bar @(rate > 90 ? "bg-danger" : "bg-success")" role="progressbar" style="width: @rate%"></div>
                                                </div>
                                                <small class="text-muted" style="font-size: 0.75rem;">@rate%</small>
                                            }
                                            else
                                            {

                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @* 수입 상세 테이블 *@
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-top-primary">
                    <div class="card-header bg-white fw-bold py-3"><i class="bi bi-plus-circle text-primary me-2"></i>📥 수입 예산 대비 달성 현황</div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0 align-middle text-center">
                            <thead class="table-light">
                                <tr><th>항목</th><th>예산액</th><th>수입액</th><th>미달성</th><th>비율</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var item in incomeStats)
                                {
                                    var rate = item.Budget == 0 ? 0 : (int)(item.Spent / item.Budget * 100);
                                    var bal = item.Budget - item.Spent;
                                    <tr class="@(item.Category.Contains("미분류") ? "table-warning" : "")">
                                        <td class="fw-bold text-start ps-4">@item.Category</td>
                                        <td class="text-end pe-3">@item.Budget.ToString("N0")</td>
                                        <td class="text-end pe-3 text-primary fw-bold">@item.Spent.ToString("N0")</td>
                                        <td class="text-end pe-3 @(bal <= 0 ? "text-success" : "text-muted")">@(bal <= 0 ? "완료" : bal.ToString("N0"))</td>
                                        <td>
                                            @if (item.Budget > 0)
                                            {
                                                <div class="progress" style="height: 6px; width: 60px; margin: 0 auto;">
                                                    <div class="progress-bar bg-primary" role="progressbar" style="width: @rate%"></div>
                                                </div>
                                                <small class="text-muted" style="font-size: 0.75rem;">@rate%</small>
                                            }
                                            else
                                            {

                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .border-top-danger {
        border-top: 3px solid #dc3545 !important;
    }

    .border-top-primary {
        border-top: 3px solid #0d6efd !important;
    }
    /* 반응형 테이블 스크롤바 커스텀 */
    .table-responsive::-webkit-scrollbar {
        height: 8px;
    }

    .table-responsive::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }
</style>

@code {
    [CascadingParameter] public User? currentUser { get; set; }

    // 부서 목록
    private List<string> Departments = new() { "영유아부", "유치부", "유년부", "초등부", "중고등부", "청년부", "교회학교운영팀" };
    private string SelectedDepartment = "";
    private int _targetYear = DateTime.Now.Year;
    public int TargetYear { get => _targetYear; set { _targetYear = value; _ = LoadDashboard(); } }

    // 단일 부서용 변수
    private decimal totalBudget = 0;
    private decimal totalSpent = 0;
    private List<StatItem> budgetStats = new();
    private List<StatItem> incomeStats = new();

    // 통합 통계용 변수 (신규)
    private List<DeptStat> integratedStats = new();

    protected override async Task OnParametersSetAsync()
    {
        if (currentUser == null) return;
        // 초기값 설정: Admin은 전체(통합), 일반 사용자는 본인 부서
        if (string.IsNullOrEmpty(SelectedDepartment))
            SelectedDepartment = (currentUser.Role == "Admin") ? "전체(통합)" : currentUser.Department;

        await LoadDashboard();
    }

    private async Task OnDepartmentChange(ChangeEventArgs e)
    {
        SelectedDepartment = e.Value?.ToString() ?? "";
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        if (SelectedDepartment == "전체(통합)")
        {
            // [Admin 기능] 통합 대시보드 로드
            integratedStats = await AccService.GetIntegratedDashboardAsync(TargetYear);
        }
        else
        {
            // [User 기능] 개별 부서 대시보드 로드
            var result = await AccService.GetDashboardDataAsync(SelectedDepartment, TargetYear);
            var inResult = await AccService.GetDashboardDataAsync(SelectedDepartment, TargetYear); // 수입용 데이터 재호출 (또는 로직 분리 가능)

            // 지출 데이터 바인딩
            totalSpent = result.TotalOut;
            budgetStats = result.Stats;
            totalBudget = budgetStats.Sum(s => s.Budget);

            // 수입 데이터 로드 (AccountingService에 수입용 메서드 분리가 이상적이나, 여기서는 로직 재사용)
            // 실제 구현 시 GetDashboardDataAsync를 개선하여 In/Out 예산을 모두 가져오도록 하면 더 효율적임.
            // 현재 구조상 수입 예산 로직을 별도로 구현하여 바인딩
            var inPlans = await AccService.GetBudgetPlansAsync(SelectedDepartment, TargetYear, "Income");
            var trans = await AccService.GetAllTransactionsAsync(TargetYear);
            var myTrans = trans.Where(t => t.Department == SelectedDepartment && t.Type == "수입").ToList();

            incomeStats = inPlans.GroupBy(p => p.Category).Select(g => new StatItem
            {
                Category = g.Key,
                Budget = g.Sum(x => x.Amount),
                Spent = myTrans.Where(t => t.Category == g.Key).Sum(t => t.Income)
            }).ToList();

            var unmappedIn = myTrans.Where(t => t.Category == "미분류").Sum(t => t.Income);
            if (unmappedIn > 0) incomeStats.Add(new StatItem { Category = "미분류", Budget = 0, Spent = unmappedIn });
        }
    }
}