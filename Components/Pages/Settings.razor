@page "/settings"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@using INcheonChurchWeb.Data
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using System.Text
@inject AccountingService AccService
@inject AppDbContext DbContext
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container mt-4 mb-5">
    <div class="card shadow-sm border-0">
        @* 상단 헤더 *@
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
            <h4 class="mb-0 fw-bold text-secondary"><i class="bi bi-gear-fill me-2"></i>환경 설정 (@(CurrentUser?.Department ?? "부서미정"))</h4>
            @if (CurrentUser?.Role != "Admin")
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-light text-dark border">현재 작업 연도:</span>
                    <div class="d-flex align-items-center gap-1">
                        <button class="btn btn-sm btn-outline-secondary fw-bold" @onclick="() => ChangeYear(-1)" disabled="@(TargetYear <= 2024)">◀</button>
                        <span class="fw-bold fs-5 px-2 text-primary" style="min-width: 80px; text-align: center;">@TargetYear 년</span>
                        <button class="btn btn-sm btn-outline-secondary fw-bold" @onclick="() => ChangeYear(1)" disabled="@(TargetYear >= DateTime.Now.Year + 1)">▶</button>
                    </div>
                    <button class="btn btn-sm btn-outline-primary ms-2" @onclick="SafeImportBaseBudget" disabled="@isImporting">
                        @if (isImporting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        else { <span>🔄 기초예산 불러오기</span> }
                    </button>
                </div>
            }
        </div>

        @* 탭 메뉴 *@
        <div class="card-header bg-light p-0 border-0">
            <ul class="nav nav-tabs border-bottom-0">
                @if (CurrentUser?.Role != "Admin")
                {
                    <li class="nav-item"><button class="nav-link @(activeTab == "Income" ? "active fw-bold text-primary" : "")" @onclick='() => ChangeTab("Income")'>📥 수입 예산</button></li>
                    <li class="nav-item"><button class="nav-link @(activeTab == "Expense" ? "active fw-bold text-danger" : "")" @onclick='() => ChangeTab("Expense")'>📤 지출 예산</button></li>
                    <li class="nav-item"><button class="nav-link @(activeTab == "Mapping" ? "active fw-bold text-warning" : "")" @onclick='() => ChangeTab("Mapping")'>🏷️ 자동분류 설정</button></li>
                    <li class="nav-item"><button class="nav-link @(activeTab == "Quarter" ? "active fw-bold text-info" : "")" @onclick='() => ChangeTab("Quarter")'>📅 분기 설정</button></li>
                    <li class="nav-item"><button class="nav-link @(activeTab == "Backup" ? "active fw-bold text-success" : "")" @onclick='() => ChangeTab("Backup")'>📂 데이터 백업</button></li>
                }
                <li class="nav-item"><button class="nav-link @(activeTab == "MyInfo" ? "active fw-bold text-dark" : "")" @onclick='() => ChangeTab("MyInfo")'>🔒 정보 변경</button></li>
                @if (CurrentUser?.Role == "Admin")
                {
                    <li class="nav-item"><button class="nav-link @(activeTab == "Users" ? "active fw-bold text-success" : "")" @onclick='() => ChangeTab("Users")'>👥 사용자 관리</button></li>
                }
            </ul>
        </div>

        <div class="card-body bg-white p-4">
            
        @* 예산/매핑 탭 공용 카테고리 목록은 @code에서 IncomeCats/ExpenseCats로 직접 사용 *@

            @* 1. 예산 관리 탭 *@
            @if (activeTab == "Income" || activeTab == "Expense")
            {
                var currentCats = activeTab == "Income" ? IncomeCats : ExpenseCats;

                <h5 class="fw-bold text-primary mb-3">
                    ✏️ @(TargetYear) 년도 @(activeTab == "Income" ? "수입" : "지출") 예산 편집
                </h5>

                @* 입력 폼 *@
                <div class="bg-light p-3 rounded mb-4 border shadow-sm">
                    <div class="row g-2 align-items-end">
                        @* 항목 — 드롭다운 select + X 버튼 *@
                        <div class="col-md-3">
                            <label class="form-label small fw-bold mb-1">항목</label>
                            <div class="input-group">
                                <select class="form-select" @bind="newPlan.Category">
                                    <option value="">-- 항목 선택 --</option>
                                    @foreach (var c in currentCats)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                </select>
                                @if (!string.IsNullOrEmpty(newPlan.Category))
                                {
                                    <button class="btn btn-outline-secondary" type="button"
                                            @onclick="() => { newPlan.Category = string.Empty; }"
                                            title="선택 초기화">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                }
                            </div>
                        </div>
                        @if (activeTab == "Expense")
                        {
                            <div class="col-md-2">
                                <label class="form-label small fw-bold mb-1">상세내역</label>
                                <div class="input-group">
                                    <input class="form-control" @bind="newPlan.SubCategory" placeholder="상세내역" />
                                    @if (!string.IsNullOrEmpty(newPlan.SubCategory))
                                    {
                                        <button class="btn btn-outline-secondary" type="button"
                                                @onclick="() => { newPlan.SubCategory = string.Empty; }"
                                                title="지우기">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        <div class="col-md-3">
                            <label class="form-label small fw-bold mb-1">산출근거</label>
                            <div class="input-group">
                                <input class="form-control" @bind="newPlan.CalcDetail" placeholder="산출근거" />
                                @if (!string.IsNullOrEmpty(newPlan.CalcDetail))
                                {
                                    <button class="btn btn-outline-secondary" type="button"
                                            @onclick="() => { newPlan.CalcDetail = string.Empty; }"
                                            title="지우기">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold mb-1">금액</label>
                            <input type="number" class="form-control text-end" @bind="newPlan.Amount" placeholder="금액" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary w-100 fw-bold" @onclick="SavePlan">
                                @((newPlan.Id == 0) ? "➕ 추가" : "💾 수정")
                            </button>
                        </div>
                    </div>
                </div>

                @* 항목 필터 (드롭다운) *@
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-secondary">항목 필터</span>
                    <div class="input-group input-group-sm" style="max-width:260px;">
                        <select class="form-select form-select-sm" @bind="budgetFilterCategory">
                            <option value="">전체 보기</option>
                            @foreach (var c in currentCats)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                        @if (!string.IsNullOrEmpty(budgetFilterCategory))
                        {
                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                    @onclick="() => { budgetFilterCategory = string.Empty; }"
                                    title="필터 초기화">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                    </div>
                    <span class="text-muted small ms-2">
                        @(budgetList.Count(b => b.Year == TargetYear &&
                            (string.IsNullOrEmpty(budgetFilterCategory) || b.Category == budgetFilterCategory)))건
                    </span>
                </div>

                <table class="table table-hover align-middle border-top mb-5">
                    <thead class="@(activeTab == "Income" ? "table-primary" : "table-danger") text-center">
                        <tr>
                            <th>항목</th>
                            @if (activeTab == "Expense") { <th>상세내역</th> }
                            <th>산출근거</th>
                            <th class="text-end">금액</th>
                            <th width="120">관리</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var filtered = budgetList
                                .Where(b => b.Year == TargetYear &&
                                    (string.IsNullOrEmpty(budgetFilterCategory) || b.Category == budgetFilterCategory))
                                .ToList();
                        }
                        @foreach (var item in filtered)
                        {
                            <tr>
                                <td class="fw-bold text-center">@item.Category</td>
                                @if (activeTab == "Expense") { <td>@item.SubCategory</td> }
                                <td class="small text-muted">@item.CalcDetail</td>
                                <td class="text-end fw-bold">@item.Amount.ToString("N0")</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => EditPlan(item)">수정</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => SafeDeletePlan(item.Id)">삭제</button>
                                </td>
                            </tr>
                        }
                        @if (!filtered.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">등록된 예산이 없습니다.</td></tr>
                        }
                    </tbody>
                    @if (filtered.Any())
                    {
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="@(activeTab == "Expense" ? 3 : 2)" class="text-end">합 계</td>
                                <td class="text-end text-primary">@filtered.Sum(b => b.Amount).ToString("N0")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>

                <hr class="my-5 border-2" />

                <h5 class="fw-bold text-secondary mb-3">📜 연도별 예산 히스토리</h5>
                <div class="accordion" id="budgetHistoryAccordion">
                    @foreach (var group in budgetHistory.Where(g => g.Key != TargetYear).OrderByDescending(g => g.Key))
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@group.Key">
                                    📂 @group.Key 년도 예산 (총 @group.Sum(x => x.Amount).ToString("N0")원)
                                </button>
                            </h2>
                            <div id="collapse-@group.Key" class="accordion-collapse collapse" data-bs-parent="#budgetHistoryAccordion">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead class="table-light"><tr><th>항목</th><th>내역</th><th>금액</th></tr></thead>
                                        <tbody>
                                            @foreach (var item in group)
                                            {
                                                <tr>
                                                    <td>@item.Category</td>
                                                    <td>@item.SubCategory @item.CalcDetail</td>
                                                    <td class="text-end">@item.Amount.ToString("N0")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            @* 2. 매핑 설정 *@
            else if (activeTab == "Mapping")
            {
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="alert alert-info small flex-grow-1 me-3 mb-0">은행 적요 키워드를 감지하여 항목을 지정합니다.</div>
                    <button class="btn btn-outline-warning fw-bold" @onclick="InitializeMappingsFrom2025">✨ 25년 장부 기반 초기화</button>
                </div>
                <div class="bg-light p-3 rounded mb-4 border">
                    <div class="row g-2">
                        <div class="col-5"><input class="form-control" @bind="newMapping.Keyword" placeholder="적요 키워드 (예: 다이소)" /></div>
                        <div class="col-5">
                            @* 드롭다운 + X 버튼 *@
                            <div class="input-group">
                                <select class="form-select" @bind="newMapping.Category">
                                    <option value="">-- 항목 선택 --</option>
                                    @foreach (var c in ExpenseCats)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                </select>
                                @if (!string.IsNullOrEmpty(newMapping.Category))
                                {
                                    <button class="btn btn-outline-secondary" type="button"
                                            @onclick="() => { newMapping.Category = string.Empty; }"
                                            title="선택 초기화">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="col-2"><button class="btn btn-warning w-100 fw-bold" @onclick="AddMapping">등록</button></div>
                    </div>
                </div>
                <table class="table table-sm table-bordered bg-white text-center shadow-sm">
                    <thead class="table-dark"><tr><th>키워드</th><th>분류될 항목</th><th>관리</th></tr></thead>
                    <tbody>
                        @foreach (var m in mappingList)
                        {
                            <tr><td>@m.Keyword</td><td>@m.Category</td><td><button class="btn btn-sm btn-link text-danger" @onclick="() => DeleteMapping(m.Id)">삭제</button></td></tr>
                        }
                    </tbody>
                </table>
            }
            @* 3. 분기 설정 *@
            else if (activeTab == "Quarter")
            {
                <div class="col-md-10 mx-auto mt-4">
                    <h5 class="fw-bold mb-3 text-info">📌 @TargetYear 년도 분기 날짜 설정</h5>
                    <div class="card p-4 shadow-sm border-info">
                        <div class="alert alert-danger border small mb-4">
                            <strong>[주의]</strong> @TargetYear 년도의 분기만 변경됩니다. <br />
                            분기 기간을 변경하면 과거 장부의 <strong>"분기별 통계값"이 즉시 다르게 계산될 수 있으니</strong> 연초에만 설정하시길 권장합니다.
                        </div>
                        @for (int q = 1; q <= 4; q++)
                        {
                            int localQ = q;
                            <div class="mb-3 row align-items-center bg-light p-2 rounded">
                                <label class="col-sm-2 col-form-label fw-bold text-center border-end">@q 분기</label>
                                <div class="col d-flex gap-2 align-items-center">
                                    <input type="date" class="form-control" @bind="QuarterDates[localQ - 1].Start" />
                                    <span>~</span>
                                    <input type="date" class="form-control" @bind="QuarterDates[localQ - 1].End" />
                                </div>
                                <div class="col-sm-2">
                                    <button class="btn btn-sm btn-outline-primary w-100 fw-bold" @onclick="() => SaveQuarter(localQ)">저장</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            @* 4. 백업 *@
            else if (activeTab == "Backup")
            {
                <div class="alert alert-success d-flex justify-content-between align-items-center">
                    <div>
                        <strong>현재 상태를 즉시 백업하여 나중에 복구할 수 있습니다.</strong><br/>
                        <input type="text" class="form-control form-control-sm mt-2" placeholder="백업 메모를 직접 적어주세요 (예: 26년 1분기 결산전)" @bind="customBackupMemo" style="width: 300px;" />
                    </div>
                    <button class="btn btn-success" @onclick='() => SafeBackup("User_Manual")'>지금 백업하기</button>
                </div>

                <h6 class="fw-bold mt-4"><i class="bi bi-clock-history me-2"></i>백업 히스토리 (다운로드 지원)</h6>
                <table class="table table-sm table-hover border align-middle text-center">
                    <thead class="table-light">
                        <tr><th>백업 일시</th><th>구분</th><th>메모 (직접입력)</th><th width="250">관리</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var b in backupList)
                        {
                            <tr>
                                <td>@b.BackupDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><span class="badge bg-secondary">@b.DataType</span></td>
                                <td class="small text-start">@b.Memo</td>
                                <td>
                                    @* 🚀 복구, 다운로드, 삭제 버튼 구성 *@
                                    <button class="btn btn-sm btn-outline-primary fw-bold px-2 py-0 me-1" @onclick="() => RestoreData(b)">🔄 복구</button>
                                    <button class="btn btn-sm btn-outline-dark fw-bold px-2 py-0 me-1" @onclick="() => DownloadBackupFile(b)">💾 다운로드</button>
                                    <button class="btn btn-sm btn-outline-danger fw-bold px-2 py-0" @onclick="() => DeleteBackup(b.Id)">🗑️ 삭제</button>
                                </td>
                            </tr>
                        }
                        @if(!backupList.Any())
                        {
                            <tr><td colspan="4" class="text-muted py-4">저장된 백업 파일이 없습니다.</td></tr>
                        }
                    </tbody>
                </table>
            }
            @* 5. 사용자 관리 *@
            else if (activeTab == "Users" && CurrentUser?.Role == "Admin")
            {
                <h5 class="mb-3 fw-bold text-success">👥 부서 계정 관리</h5>
                <div class="row g-2 mb-3 bg-light p-3 border rounded">
                    <div class="col-3"><input class="form-control" @bind="newUser.Username" placeholder="ID" /></div>
                    <div class="col-3"><input class="form-control" @bind="newUser.Password" placeholder="PW" /></div>
                    <div class="col-3"><input class="form-control" @bind="newUser.Department" placeholder="부서명" /></div>
                    <div class="col-2"><select class="form-select" @bind="newUser.Role"><option value="User">일반사용자</option><option value="Admin">관리자</option></select></div>
                    <div class="col-1"><button class="btn btn-primary w-100" @onclick="AddUser">등록</button></div>
                </div>
                <table class="table border">
                    <thead class="table-light text-center"><tr><th>아이디</th><th>소속 부서</th><th>권한</th><th>관리</th></tr></thead>
                    <tbody>
                        @foreach (var u in userList)
                        {
                            <tr>
                                <td class="text-center">@u.Username</td>
                                <td class="text-center">@u.Department</td>
                                <td class="text-center">@u.Role</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-warning me-1" @onclick="() => ResetPassword(u.Username)">초기화</button>
                                    @if (u.Username != "admin")
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(u.Username)">삭제</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            @* 6. 내 정보 (비밀번호 변경 및 확인) *@
            else if (activeTab == "MyInfo")
            {
                <div class="col-md-6 mx-auto mt-5">
                    <div class="card p-4 border-0 shadow-sm bg-light">
                        <h5 class="mb-4 fw-bold text-center">🔒 보안 및 정보</h5>
                        
                        @* 🚀 현재 비밀번호 노출 (본인 확인용) *@
                        <div class="alert alert-secondary border text-center mb-4">
                            현재 내 비밀번호는 <strong>[ @currentVisiblePassword ]</strong> 입니다.
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-danger">새로운 비밀번호 입력</label>
                            <input type="text" class="form-control border-danger" @bind="newSelfPassword" placeholder="변경할 비밀번호를 입력하세요" />
                        </div>
                        <button class="btn btn-dark w-100 py-2 fw-bold" @onclick="ChangeMyPassword">변경 내용 저장</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // JSON 파일을 PC로 다운로드 시키는 자바스크립트 함수
    window.downloadJsonFile = (fileName, jsonContent) => {
        const blob = new Blob([jsonContent], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.download = fileName;
        link.href = url;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
    }
</script>

@code {
    [CascadingParameter] public User? CurrentUser { get; set; }
    private string activeTab = "Income";
    private int TargetYear = DateTime.Now.Year;
    private bool isImporting = false; 

    // 자동완성을 위한 하드코딩 카테고리 배열
    private readonly string[] IncomeCats = new[] { "주일헌금", "찬조금", "이월금", "교회보조금", "은행이자", "회비수입", "기타수입" };
    private readonly string[] ExpenseCats = new[] { "행사비", "공과비", "교육활동비", "겨울성경학교", "여름성경학교", "운영비", "간식비", "부서관리비", "교사회의비", "훈련비", "기타지출" };

    private List<BudgetPlan> budgetList = new(); 
    private IGrouping<int, BudgetPlan>[] budgetHistory = Array.Empty<IGrouping<int, BudgetPlan>>(); 

    private BudgetPlan newPlan = new();
    private List<CategoryMapping> mappingList = new();
    private CategoryMapping newMapping = new();
    private List<DataBackup> backupList = new();
    private List<User> userList = new();
    private User newUser = new();
    
    private string newSelfPassword = "";
    private string currentVisiblePassword = ""; // 현재 비밀번호 노출용
    private string customBackupMemo = ""; // 백업 직접 메모용
    private string budgetFilterCategory = ""; // 예산 항목 필터

    class DateRange { public DateTime Start { get; set; } public DateTime End { get; set; } }
    private DateRange[] QuarterDates = new DateRange[4] { new(), new(), new(), new() };

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser == null) return;
        activeTab = (CurrentUser.Role == "Admin") ? "Users" : "Income";
        TargetYear = Math.Max(2024, DateTime.Now.Year);
        
        // 초기화 시 현재 비밀번호 조회
        var user = await DbContext.Users.FindAsync(CurrentUser.Username);
        if (user != null) currentVisiblePassword = user.Password;

        await LoadData();
    }

    private async Task ChangeYear(int offset)
    {
        int newYear = TargetYear + offset;
        int maxYear = DateTime.Now.Year + 1;
        if (newYear >= 2024 && newYear <= maxYear)
        {
            TargetYear = newYear;
            await LoadData();
        }
    }

    private async Task ChangeTab(string tab) { activeTab = tab; newPlan = new(); budgetFilterCategory = ""; await LoadData(); }

    private async Task LoadData()
    {
        if (CurrentUser == null) return;
        string dept = CurrentUser.Department;

        if (activeTab == "Users") userList = await AccService.GetAllUsersAsync();
        else if (activeTab == "Income" || activeTab == "Expense")
        {
            var allPlans = await DbContext.BudgetPlans.AsNoTracking()
                                .Where(b => b.Department == dept && b.Type == activeTab)
                                .OrderBy(b => b.Year).ThenBy(b => b.Category)
                                .ToListAsync();

            budgetList = allPlans; 
            budgetHistory = allPlans.GroupBy(b => b.Year).ToArray();
        }
        else if (activeTab == "Mapping")
        {
            mappingList = await AccService.GetMappingsAsync(dept);
        }
        else if (activeTab == "Backup")
        {
            backupList = await AccService.GetBackupsAsync(dept);
        }
        else if (activeTab == "Quarter")
        {
            for (int i = 1; i <= 4; i++)
            {
                var range = await AccService.GetQuarterDateRangeAsync(dept, TargetYear, i);
                QuarterDates[i - 1] = new DateRange { Start = range.Start, End = range.End };
            }
        }
    }

    private async Task SavePlan()
    {
        if (string.IsNullOrWhiteSpace(newPlan.Category)) return;
        newPlan.Year = TargetYear;
        newPlan.Type = activeTab;
        newPlan.Department = CurrentUser.Department;
        await AccService.SaveBudgetPlanAsync(newPlan);
        newPlan = new();
        await LoadData();
    }

    // 🚀 분기 저장 전 경고 로직 추가
    private async Task SaveQuarter(int q)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"정말 {TargetYear}년도의 {q}분기 기간을 변경하시겠습니까?\n\n" +
            $"과거 통계 내역이 달라질 수 있습니다.");
        if (!confirmed) return;

        var range = QuarterDates[q - 1];
        await AccService.SaveQuarterSettingAsync(CurrentUser.Department, TargetYear, q, range.Start, range.End);
        await JSRuntime.InvokeVoidAsync("alert", $"{TargetYear}년도 {q}분기 기간이 설정되었습니다.");
    }

