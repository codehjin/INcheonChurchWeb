    // 🚀 비밀번호 변경 시 경고 및 메모리 반영
    private async Task ChangeMyPassword() 
    { 
        if (string.IsNullOrWhiteSpace(newSelfPassword))
        {
            await JSRuntime.InvokeVoidAsync("alert", "새 비밀번호를 입력해주세요.");
            return;
        }

        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"[{newSelfPassword}] (으)로 비밀번호를 변경하시겠습니까?\n" +
            $"⚠️ 잊어버리지 않도록 반드시 메모하여 보관하세요!");

        if (confirmed)
        {
            await AccService.ChangePasswordAsync(CurrentUser.Username, newSelfPassword); 
            currentVisiblePassword = newSelfPassword; // 화면 갱신
            newSelfPassword = "";
            await JSRuntime.InvokeVoidAsync("alert", "비밀번호가 성공적으로 변경되었습니다.");
        }
    }
