    private async Task SafeImportBaseBudget()
    {
        if (isImporting) return; 
        
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"[{TargetYear}년도] 기초예산을 불러옵니다.\n\n" +
            $"※ 하드코딩된 유년부 기본 예산 양식이 일괄 적용됩니다.\n" +
            $"※ 이미 금액이 있는 데이터는 안전하게 보호됩니다.\n\n" +
            $"계속하시겠습니까?");
            
        if (!confirmed) return;

        isImporting = true;
        StateHasChanged(); 

        try
        {
            string dept = CurrentUser.Department;

            var existingPlans = await DbContext.BudgetPlans
                .Where(b => b.Department == dept && b.Year == TargetYear)
                .ToListAsync();

            if (existingPlans.Any(x => x.Amount > 0))
            {
                await JSRuntime.InvokeVoidAsync("alert", $"⚠️ {TargetYear}년도에 이미 입력된 예산 데이터가 있습니다.\n덮어쓰기를 원하시면 기존 항목을 삭제해 주세요.");
                return;
            }

            if (existingPlans.Any())
            {
                DbContext.BudgetPlans.RemoveRange(existingPlans);
                await DbContext.SaveChangesAsync(); 
            }

            var basePlans = GetDefaultBudgetPlans(dept, TargetYear);

            if (!basePlans.Any())
            {
                await JSRuntime.InvokeVoidAsync("alert", $"⚠️ '{dept}' 부서의 기초 예산 템플릿이 없습니다.");
                return;
            }

            DbContext.BudgetPlans.AddRange(basePlans);
            await DbContext.SaveChangesAsync(); 

            await LoadData(); 
            await JSRuntime.InvokeVoidAsync("alert", $"✅ {TargetYear}년도 기초예산 불러오기 완료!");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"❌ 불러오기 실패: {ex.Message}");
        }
        finally
        {
            isImporting = false;
        }
    }

    // 🚀 백업 로직 보완 (사용자 직접 입력 메모 추가)
    private async Task SafeBackup(string type) 
    { 
        string finalMemo = string.IsNullOrWhiteSpace(customBackupMemo) ? "사용자 수동 백업" : customBackupMemo;
        
        // 장부 데이터(Ledger) 전체를 백업하도록 강제 지정
        await AccService.CreateBackupAsync(CurrentUser.Department, "Ledger", finalMemo); 
        
        customBackupMemo = ""; // 저장 후 초기화
        await LoadData(); 
        await JSRuntime.InvokeVoidAsync("alert", "성공적으로 백업되었습니다.");
    }
    
    private async Task RestoreData(DataBackup b) { if (await JSRuntime.InvokeAsync<bool>("confirm", "복구하시겠습니까?\n현재 데이터는 덮어쓰기 됩니다.")) { await AccService.RestoreFromBackupAsync(b.Id); await LoadData(); } }
    
    // 🚀 백업 데이터 삭제 기능
    private async Task DeleteBackup(int backupId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "이 백업 파일을 완전히 삭제하시겠습니까?"))
        {
            var target = await DbContext.DataBackups.FindAsync(backupId);
            if (target != null)
            {
                DbContext.DataBackups.Remove(target);
                await DbContext.SaveChangesAsync();
                await LoadData();
            }
        }
    }

    // 🚀 백업 데이터 외부 다운로드 기능 (.json)
