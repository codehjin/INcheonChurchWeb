@page "/expense-report-quarterly"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@using System.Text.Json
@inject AccountingService AccService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

@* ══════════════════════════════════════════
   화면 전용 UI (인쇄 시 숨김)
══════════════════════════════════════════ *@
<div class="no-print">

    @* 상단 타이틀 바 *@
    <div class="card p-3 border-0 shadow-sm mb-3 bg-light">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex gap-3 align-items-center">
                <h4 class="fw-bold mb-0 text-primary">
                    <i class="bi bi-file-earmark-text me-2"></i>지출결의서 작성
                </h4>
                <div class="vr"></div>
                @* 회계연도 좌우 화살표 *@
                <div class="d-flex align-items-center gap-1">
                    <button class="btn btn-sm btn-outline-secondary px-2" @onclick="PrevYear">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span class="fw-bold px-2" style="min-width:60px;text-align:center;">@(TargetYear)년</span>
                    <button class="btn btn-sm btn-outline-secondary px-2" @onclick="NextYear">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-warning fw-bold" @onclick="NewReport">
                    <i class="bi bi-plus-circle me-1"></i>신규 작성
                </button>
                <button class="btn btn-dark" @onclick="PrintPage">
                    <i class="bi bi-printer-fill me-1"></i>인쇄
                </button>
            </div>
        </div>
    </div>

    <div class="row g-3">

        @* ── ① 기존 신청 내역 ── *@
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-clock-history me-2"></i>① 기존 신청 내역</span>
                    <span class="badge bg-light text-dark">
                        @(TargetYear)년 · 총 @(reportHistory.Count)건 · @(reportHistory.Sum(r => r.TotalAmount).ToString("N0"))원
                    </span>
                </div>
                <div class="card-body p-0 table-responsive" style="max-height:200px;">
                    <table class="table table-hover mb-0 text-center small align-middle">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th width="80">작성일</th>
                                <th class="text-start">청구인/제목</th>
                                <th width="110">금액</th>
                                <th width="60">관리</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var report in reportHistory)
                            {
                                <tr class="@(CurrentReport.Id == report.Id ? "table-warning" : "")"
                                    style="cursor:pointer" @onclick="() => LoadReport(report)">
                                    <td>@report.Date.ToString("yy-MM-dd")</td>
                                    <td class="text-start">@report.Title</td>
                                    <td class="text-end fw-bold text-danger">@report.TotalAmount.ToString("N0")</td>
                                    <td>
                                        <button class="btn btn-sm btn-link text-danger p-0"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => DeleteReport(report)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!reportHistory.Any())
                            {
                                <tr><td colspan="4" class="py-3 text-muted">신청 내역이 없습니다.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* ── ② 내역 입력 ── *@
        <div class="col-lg-5">
            <div class="card shadow-sm border-primary h-100">
                <div class="card-header bg-primary text-white fw-bold">
                    ② 내역 입력 (@(CurrentReport.Id == 0 ? "신규" : "수정중"))
                </div>
                <div class="card-body bg-light">
                    @* 잔액 현황 *@
                    <div class="alert alert-warning small mb-3 py-2">
                        <div class="d-flex justify-content-between">
                            <span>총 예산(수령액):</span>
                            <span class="fw-bold">@TotalBudget.ToString("N0") 원</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>기 신청액:</span>
                            <span class="fw-bold text-danger">－ @UsedBudget.ToString("N0") 원</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>이번 신청액:</span>
                            <span class="fw-bold text-primary">－ @CurrentRequestTotal.ToString("N0") 원</span>
                        </div>
                        <hr class="my-1" />
                        <div class="d-flex justify-content-between fw-bold">
                            <span>신청 후 잔액:</span>
                            <span class="@((TotalBudget - UsedBudget - CurrentRequestTotal) < 0 ? "text-danger" : "")">
                                @((TotalBudget - UsedBudget - CurrentRequestTotal).ToString("N0")) 원
                            </span>
                        </div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold mb-1">청구일자</label>
                            <input type="date" class="form-control form-control-sm" @bind="CurrentReport.Date" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold mb-1">청구인</label>
                            <input class="form-control form-control-sm" @bind="CurrentReport.Title" placeholder="이름" />
                        </div>
                    </div>

                    <div class="card p-2 border mb-3">
                        <div class="row g-1 mb-2">
                            <div class="col-4">
                                <input class="form-control form-control-sm" list="expCats"
                                       @bind="newItem.Category" placeholder="지출항목" />
                                <datalist id="expCats">
                                    @foreach (var c in catList) { <option value="@c" /> }
                                </datalist>
                            </div>
                            <div class="col-5">
                                <input class="form-control form-control-sm"
                                       @bind="newItem.CalcDetail" placeholder="산출근거" />
                            </div>
                            <div class="col-3">
                                <input type="number" class="form-control form-control-sm"
                                       @bind="newItem.Amount" placeholder="금액" @onkeyup="EnterKey" />
                            </div>
                        </div>
                        <button class="btn btn-sm btn-outline-primary w-100" @onclick="AddItem">
                            <i class="bi bi-arrow-down me-1"></i>명세에 추가
                        </button>
                    </div>

                    @* 입력된 항목 목록 *@
                    @if (itemList.Any())
                    {
                        <div class="table-responsive mb-3" style="max-height:160px;overflow-y:auto;">
                            <table class="table table-sm table-bordered mb-0" style="font-size:12px;">
                                <tbody>
                                    @foreach (var item in itemList)
                                    {
                                        <tr>
                                            <td class="fw-bold" style="width:30%">@item.Category</td>
                                            <td>@item.CalcDetail</td>
                                            <td class="text-end fw-bold" style="width:25%">@item.Amount.ToString("N0")</td>
                                            <td style="width:30px;text-align:center;">
                                                <button class="btn btn-sm btn-link text-danger p-0"
                                                        @onclick="() => RemoveItem(item)">×</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <button class="btn btn-primary w-100 fw-bold" @onclick="SaveReport">
                        <i class="bi bi-save me-1"></i>결의서 저장
                    </button>
                </div>
            </div>
        </div>

        @* ── ③ 미리보기 (실제 크기) ── *@
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-eye me-2"></i>③ 지출결의서 미리보기
                </div>
                <div class="card-body d-flex align-items-start justify-content-center py-3"
                     style="background:#e9ecef;overflow-x:auto;overflow-y:auto;max-height:860px;">
                    <div class="expense-paper">
                        @PaperMarkup
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@* ══════════════════════════════════════════
   인쇄 전용 영역 (화면에서는 숨김)
══════════════════════════════════════════ *@
<div class="print-only">
    <div class="a4-sheet">
        <div class="cut-line-v"><span class="scissors">✂</span></div>
        <div class="cut-line-h"><span class="scissors-h">✂</span></div>
        <div class="expense-paper">
            @PaperMarkup
        </div>
    </div>
</div>

@* ══════════════════════════════════════════
   결의서 본문 마크업 (미리보기 + 인쇄 공용)
══════════════════════════════════════════ *@
@{
    // 결의서 공용 마크업을 변수로 선언 (RenderFragment 아님 - 직접 인라인)
}

<style>
/* ── 화면 ── */
@@media screen {
    .print-only { display: none !important; }
    .expense-paper {
        border: 1px solid #bbb;
        box-shadow: 0 2px 12px rgba(0,0,0,.12);
    }
}

/* ── 공통 결의서 스타일 ── */
.expense-paper {
    width: 135mm;
    min-height: 195mm;
    padding: 5mm 6mm 4mm;
    background: #fff;
    font-family: 'Malgun Gothic','Dotum','돋움',sans-serif;
    font-size: 8pt;
    box-sizing: border-box;
    color: #000;
}
.ep-title {
    text-align: center;
    font-size: 15pt;
    font-weight: 900;
    letter-spacing: 7px;
    margin-bottom: 3mm;
}
.ep-header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2mm;
}
.ep-date-box {
    font-size: 8pt;
    display: flex;
    align-items: center;
    gap: 1px;
    padding-top: 2mm;
}
.ep-date-num {
    font-weight: bold;
    font-size: 9pt;
    min-width: 16px;
    text-align: center;
}
/* 결재란 */
.ep-approval { border-collapse: collapse; font-size: 7pt; }
.ep-approval td { border: 1px solid #222; text-align: center; padding: 0; }
.ep-apr-side {
    background: #ebebeb;
    font-weight: bold;
    width: 12px;
    font-size: 7pt;
    line-height: 1.6;
    padding: 2px 3px;
    vertical-align: middle;
    writing-mode: vertical-lr;
    letter-spacing: 2px;
}
.ep-apr-title { width: 21mm; font-size: 7pt; padding: 2px; height: 6mm; vertical-align: middle; }
.ep-apr-sign  { height: 15mm; }
.ep-apr-sign td { width: 21mm; }

.ep-request {
    font-size: 8pt;
    font-weight: bold;
    border-bottom: 1.5px solid #000;
    padding-bottom: 1.5mm;
    margin-bottom: 0;
}
/* 메인 테이블 */
.ep-main { width: 100%; border-collapse: collapse; border-top: 1px solid #444; }
.ep-main td { border: 1px solid #555; vertical-align: middle; }
.ep-lbl {
    background: #f0f0f0;
    font-weight: bold;
    text-align: center;
    white-space: nowrap;
    width: 16mm;
    padding: 2px;
    font-size: 8pt;
}
.ep-val { padding: 2px 5px; font-size: 8pt; }
.ep-amount-kr  { font-weight: bold; margin-bottom: 1px; }
.ep-amount-num { font-weight: bold; font-size: 8.5pt; }
/* 명세 */
.ep-detail-cell { padding: 0 !important; vertical-align: top; }
.ep-detail { width: 100%; border-collapse: collapse; font-size: 7.5pt; }
.ep-detail th {
    background: #f0f0f0; border: 1px solid #aaa;
    text-align: center; padding: 1.5px 2px; font-size: 7pt;
}
.ep-detail td {
    border: 1px solid #ccc; padding: 0.5px 3px;
    height: 5.5mm; text-align: center;
}
.ep-td-left  { text-align: left  !important; }
.ep-td-right { text-align: right !important; font-weight: bold; }
.ep-sum td {
    background: #e8e8e8; font-weight: bold;
    text-align: right; border-top: 1.5px solid #444; padding: 1.5px 3px;
}
/* 계좌 */
.ep-account { width: 100%; border-collapse: collapse; margin-top: 1.5mm; font-size: 7pt; }
.ep-account td { border: 1px solid #555; }
.ep-acc-hd  { background: #f0f0f0; text-align: center; padding: 1.5px 2px; font-weight: bold; }
.ep-acc-val { text-align: center; padding: 1px 2px; height: 6mm; vertical-align: middle; }
/* 청구 정보 */
.ep-claim { width: 100%; border-collapse: collapse; margin-top: 1mm; font-size: 8pt; }
.ep-claim td { border: 1px solid #555; }
.ep-cval { padding: 2px 6px; height: 7mm; vertical-align: middle; }
.ep-seal { color: #666; font-size: 7.5pt; }
.ep-footer { text-align: right; font-size: 8.5pt; font-weight: bold; margin-top: 1.5mm; }

/* ── 인쇄 ── */
@@media print {
    /* 화면 UI 숨김 */
    .no-print { display: none !important; }

    /* ★ Blazor MainLayout 사이드바·헤더·네비 전체 숨김 */
    nav, header, aside, footer,
    .sidebar, .top-row, .navbar, .nav-menu,
    .bi-list, [class*="sidebar"], [class*="nav-"],
    .mud-drawer, .mud-appbar,
    .layout-sidebar, .page-header,
    a.nav-link { display: none !important; }

    /* 레이아웃 여백 초기화 */
    .page, .main, article, .content,
    .page > main, main > article {
        margin: 0 !important;
        padding: 0 !important;
        max-width: none !important;
        width: 100% !important;
    }

    @@page { size: A4; margin: 0; }

    body, html { margin: 0 !important; padding: 0 !important; background: white !important; }

    .print-only { display: block !important; }

    .a4-sheet {
        position: relative;
        width: 210mm;
        height: 297mm;
        background: white;
        overflow: hidden;
    }

    .a4-sheet .expense-paper {
        position: absolute;
        top: 10mm;
        left: 10mm;
        width: 135mm !important;
        height: 195mm !important;
        min-height: unset !important;
        padding: 5mm 6mm 4mm !important;
        border: none !important;
        box-shadow: none !important;
        overflow: hidden;
    }

    /* 가위선 — 세로 (우측) */
    .cut-line-v {
        position: absolute;
        top: 0; left: 153mm;
        width: 0; height: 215mm;
        border-left: 1px dashed #999;
        display: flex; justify-content: center; align-items: flex-start;
    }
    .scissors { font-size: 10pt; margin-top: 3mm; transform: rotate(90deg); display: inline-block; color: #777; }

    /* 가위선 — 가로 (하단) */
    .cut-line-h {
        position: absolute;
        top: 213mm; left: 0;
        height: 0; width: 162mm;
        border-top: 1px dashed #999;
        display: flex; align-items: center;
    }
    .scissors-h { font-size: 10pt; margin-left: 3mm; color: #777; }

    /* 배경색 강제 출력 */
    .ep-lbl, .ep-apr-side, .ep-apr-title,
    .ep-acc-hd, .ep-detail th, .ep-sum td {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
    }
}
</style>

@* ══════════════════════════════════════════
   @code 블록
══════════════════════════════════════════ *@
@code {
    [CascadingParameter] public User? CurrentUser { get; set; }

    private int    TargetYear    = DateTime.Now.Year;
    private decimal TotalBudget  = 0;
    private decimal UsedBudget   = 0;

    private ExpenseReport        CurrentReport = new() { Date = DateTime.Now };
    private List<BudgetPlan>     itemList      = new();
    private BudgetPlan           newItem       = new();
    private List<ExpenseReport>  reportHistory = new();
    private List<string>         catList       = new();

    private decimal CurrentRequestTotal => itemList.Sum(x => x.Amount);

    // ── 결의서 공용 마크업 (RenderFragment) ──
    private RenderFragment PaperMarkup => __builder =>
    {
        // 제목
        <div class="ep-title">지 출 결 의 서</div>

        // 날짜 + 결재란
        <div class="ep-header-row">
            <div class="ep-date-box">
                <span>20</span>
                <span class="ep-date-num">@CurrentReport.Date.ToString("yy")</span>
                <span>년&nbsp;</span>
                <span class="ep-date-num">@CurrentReport.Date.ToString("MM")</span>
                <span>월&nbsp;</span>
                <span class="ep-date-num">@CurrentReport.Date.ToString("dd")</span>
                <span>일</span>
            </div>
            <table class="ep-approval">
                <tbody>
                    <tr>
                        <td class="ep-apr-side" rowspan="2">결재</td>
                        <td class="ep-apr-title">팀 장</td>
                        <td class="ep-apr-title">국 장</td>
                        <td class="ep-apr-title">관리국장</td>
                        <td class="ep-apr-title">담임목사</td>
                    </tr>
                    <tr class="ep-apr-sign">
                        <td></td><td></td><td></td><td></td>
                    </tr>
                </tbody>
            </table>
        </div>

        // 부탁 문구
        <div class="ep-request">아래와 같이 지출하여 주시기 바랍니다.</div>

        // 메인 테이블
        <table class="ep-main">
            <tr>
                <td class="ep-lbl">금&nbsp;&nbsp;액</td>
                <td class="ep-val" colspan="2">
                    <div class="ep-amount-kr">一金 @AmountInKorean</div>
                    <div class="ep-amount-num">₩ @CurrentRequestTotal.ToString("N0")</div>
                </td>
            </tr>
            <tr>
                <td class="ep-lbl">지출항목</td>
                <td class="ep-val" colspan="2">@CurrentUser?.Department</td>
            </tr>
            <tr>
                <td class="ep-lbl" style="vertical-align:middle;">적&nbsp;&nbsp;요</td>
                <td class="ep-detail-cell" colspan="2">
                    <table class="ep-detail">
                        <thead>
                            <tr>
                                <th style="width:30%">지출항목</th>
                                <th style="width:50%">산출근거</th>
                                <th style="width:20%">금액</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in itemList)
                            {
                                <tr>
                                    <td>@item.Category</td>
                                    <td class="ep-td-left">@item.CalcDetail</td>
                                    <td class="ep-td-right">@item.Amount.ToString("N0")</td>
                                </tr>
                            }
                            @for (int i = 0; i < Math.Max(0, 7 - itemList.Count); i++)
                            {
                                <tr><td>&nbsp;</td><td></td><td></td></tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="ep-sum">
                                <td colspan="2">합 계 :</td>
                                <td class="ep-td-right">@CurrentRequestTotal.ToString("N0")</td>
                            </tr>
                        </tfoot>
                    </table>
                </td>
            </tr>
        </table>

        // 계좌
        <table class="ep-account">
            <tr>
                <td class="ep-lbl" rowspan="2">계&nbsp;&nbsp;좌</td>
                <td class="ep-acc-hd">지급방법</td>
                <td class="ep-acc-hd">은행명</td>
                <td class="ep-acc-hd">계좌번호</td>
                <td class="ep-acc-hd">예금주</td>
            </tr>
            <tr>
                <td class="ep-acc-val">현금□ 계좌□</td>
                <td class="ep-acc-val">하나은행</td>
                <td class="ep-acc-val">449-910027-73104</td>
                <td class="ep-acc-val">인천중앙교회(유년부)</td>
            </tr>
        </table>

        // 청구정보
        <table class="ep-claim">
            <tr>
                <td class="ep-lbl">청구날짜</td>
                <td class="ep-cval">@CurrentReport.Date.ToString("yyyy년 M월 d일")</td>
            </tr>
            <tr>
                <td class="ep-lbl">청&nbsp;구&nbsp;인</td>
                <td class="ep-cval">@CurrentReport.Title <span class="ep-seal">(인)</span></td>
            </tr>
            <tr>
                <td class="ep-lbl">지출날짜</td>
                <td class="ep-cval">&nbsp;</td>
            </tr>
        </table>

        <div class="ep-footer">인천중앙교회</div>
    };

    // ── 회계연도 화살표 ──
    private async Task PrevYear() { TargetYear--; await LoadData(); }
    private async Task NextYear() { TargetYear++; await LoadData(); }

    // ── 한글 금액 ──
    private string AmountInKorean
    {
        get
        {
            long n = (long)CurrentRequestTotal;
            if (n == 0) return "영원정";
            string[] ones     = { "", "일", "이", "삼", "사", "오", "육", "칠", "팔", "구" };
            string[] units    = { "", "십", "백", "천" };
            string[] bigUnits = { "", "만", "억", "조" };
            string result = "";
            int groupIdx = 0;
            while (n > 0)
            {
                long group = n % 10000;
                if (group != 0)
                {
                    string gs = "";
                    for (int i = 3; i >= 0; i--)
                    {
                        int d = (int)((group / (long)Math.Pow(10, i)) % 10);
                        if (d > 0) gs += ones[d] + units[i];
                    }
                    result = gs + bigUnits[groupIdx] + result;
                }
                n /= 10000; groupIdx++;
            }
            return result + "원정";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser == null) return;
        await LoadData();
        catList = await AccService.GetCategorySuggestionsAsync(CurrentUser.Department, "Expense");
    }

    private async Task LoadData()
    {
        if (CurrentUser == null) return;
        var status    = await AccService.GetSubsidyStatusForReportAsync(CurrentUser.Department, TargetYear);
        TotalBudget   = status.TotalReceived;
        UsedBudget    = status.TotalUsed;
        reportHistory = await AccService.GetExpenseReportsAsync(CurrentUser.Department, TargetYear);
    }

    private void NewReport()
    {
        CurrentReport = new ExpenseReport
        {
            Date       = DateTime.Now,
            Department = CurrentUser?.Department ?? "",
            FiscalYear = TargetYear
        };
        itemList.Clear();
        newItem = new();
    }

    private async Task AddItem()
    {
        if (string.IsNullOrWhiteSpace(newItem.Category) || newItem.Amount <= 0) return;
        if (TotalBudget > 0 && UsedBudget + CurrentRequestTotal + newItem.Amount > TotalBudget)
        {
            await JSRuntime.InvokeVoidAsync("alert", "예산 잔액을 초과합니다.");
            return;
        }
        itemList.Add(new BudgetPlan
        {
            Category   = newItem.Category,
            CalcDetail = newItem.CalcDetail,
            Amount     = newItem.Amount
        });
        newItem.CalcDetail = "";
        newItem.Amount     = 0;
    }

    private void RemoveItem(BudgetPlan item) => itemList.Remove(item);

    private async Task SaveReport()
    {
        if (!itemList.Any())
        {
            await JSRuntime.InvokeVoidAsync("alert", "내역을 입력하세요."); return;
        }
        if (string.IsNullOrWhiteSpace(CurrentReport.Title))
        {
            await JSRuntime.InvokeVoidAsync("alert", "청구인을 입력하세요."); return;
        }
        CurrentReport.Department  = CurrentUser?.Department ?? "";
        CurrentReport.FiscalYear  = TargetYear;
        CurrentReport.TotalAmount = CurrentRequestTotal;
        CurrentReport.DetailsJson = JsonSerializer.Serialize(itemList);
        await AccService.SaveExpenseReportAsync(CurrentReport);
        await LoadData();
        await JSRuntime.InvokeVoidAsync("alert", "저장되었습니다.");
    }

    private void LoadReport(ExpenseReport report)
    {
        CurrentReport = new ExpenseReport
        {
            Id         = report.Id,
            Date       = report.Date,
            Title      = report.Title,
            FiscalYear = report.FiscalYear,
            Department = report.Department,
            TotalAmount = report.TotalAmount
        };
        try   { itemList = JsonSerializer.Deserialize<List<BudgetPlan>>(report.DetailsJson) ?? new(); }
        catch { itemList = new(); }
    }

    private async Task DeleteReport(ExpenseReport report)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "정말 삭제하시겠습니까?"))
        {
            await AccService.DeleteExpenseReportAsync(report.Id);
            await LoadData();
            NewReport();
        }
    }

    private void EnterKey(KeyboardEventArgs e) { if (e.Key == "Enter") _ = AddItem(); }

    private async Task PrintPage()
    {
        // 인쇄 전: 사이드바/헤더 숨김 → 인쇄 → 복원
        await JSRuntime.InvokeVoidAsync("eval", @"
            (function(){
                var style = document.createElement('style');
                style.id = '__printHide';
                style.innerHTML =
                    '@media print {' +
                    '  nav, header, aside, .sidebar, .top-row, .navbar, ' +
                    '  [class*=""nav-""], .mud-drawer, .mud-appbar,' +
                    '  .page > div:first-child { display:none!important; }' +
                    '  .page, .main, article, .content { margin:0!important; padding:0!important; }' +
                    '}';
                document.head.appendChild(style);
                window.print();
                setTimeout(function(){ var s=document.getElementById('__printHide'); if(s) s.remove(); }, 2000);
            })();
        ");
    }
}
