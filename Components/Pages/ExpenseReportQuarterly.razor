@page "/expense-report-quarterly"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@using System.Text.Json
@inject AccountingService AccService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container mt-4 mb-5 no-print">
    @* [1] 상단 컨트롤 패널 *@
    <div class="card p-3 border-0 shadow-sm mb-4 bg-light">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex gap-3 align-items-center">
                <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-file-earmark-text me-2"></i>지출결의서 작성</h4>
                <div class="vr"></div>
                <div class="input-group input-group-sm w-auto">
                    <span class="input-group-text">회계연도</span>
                    <input type="number" class="form-control" @bind="TargetYear" style="width: 80px;" />
                    <button class="btn btn-secondary" @onclick="LoadData">조회</button>
                </div>
            </div>
            <div>
                <button class="btn btn-warning fw-bold me-2" @onclick="NewReport">
                    <i class="bi bi-plus-circle me-1"></i>신규 작성
                </button>
                <button class="btn btn-dark" onclick="window.print()">
                    <i class="bi bi-printer-fill me-1"></i>인쇄
                </button>
            </div>
        </div>
    </div>

    @* [2] 작성 폼 (보조금 현황 포함) *@
    <div class="row">
        @* 왼쪽: 입력 폼 *@
        <div class="col-lg-5">
            <div class="card shadow-sm border-primary h-100">
                <div class="card-header bg-primary text-white fw-bold">
                    내역 입력 (@(CurrentReport.Id == 0 ? "신규" : "수정중"))
                </div>
                <div class="card-body bg-light">
                    @* 잔액 현황 *@
                    <div class="alert alert-warning shadow-sm small mb-3">
                        <div class="d-flex justify-content-between">
                            <span>총 예산(수령액):</span>
                            <span class="fw-bold">@TotalBudget.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>현재까지 신청액:</span>
                            <span class="fw-bold text-danger">- @UsedBudget.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>이번 신청액:</span>
                            <span class="fw-bold text-primary">- @CurrentRequestTotal.ToString("N0")</span>
                        </div>
                        <hr class="my-1" />
                        <div class="d-flex justify-content-between fw-bold text-dark" style="font-size: 1.1em;">
                            <span>신청 후 잔액:</span>
                            <span>@((TotalBudget - UsedBudget - CurrentRequestTotal).ToString("N0"))원</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">결의서 제목</label>
                        <input class="form-control" @bind="CurrentReport.Title" placeholder="예: 3월 1주 주일간식비" />
                    </div>

                    <div class="card p-2 border mb-3">
                        <div class="row g-1 mb-2">
                            <div class="col-4">
                                <input class="form-control form-control-sm" list="expCats" @bind="newItem.Category" placeholder="항목" />
                                <datalist id="expCats">@foreach(var c in catList){
                                <option value="@c" />
                                                                }
</datalist>
                            </div>
                            <div class="col-4">
                                <input class="form-control form-control-sm" @bind="newItem.CalcDetail" placeholder="내역" />
                            </div>
                            <div class="col-4">
                                <input type="number" class="form-control form-control-sm" @bind="newItem.Amount" placeholder="금액" @onkeyup="EnterKey" />
                            </div>
                        </div>
                        <button class="btn btn-sm btn-outline-primary w-100" @onclick="AddItem">
                            <i class="bi bi-arrow-down me-1"></i>아래 명세서에 추가
                        </button>
                    </div>

                    <button class="btn btn-primary w-100 fw-bold py-2" @onclick="SaveReport">
                        <i class="bi bi-save me-1"></i>결의서 저장 (잔액 반영)
                    </button>
                </div>
            </div>
        </div>

        @* 오른쪽: 신청 내역 히스토리 *@
        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-secondary text-white fw-bold">
                    <i class="bi bi-clock-history me-2"></i>기존 신청 내역 (하단 클릭 시 불러오기)
                </div>
                <div class="card-body p-0 table-responsive" style="max-height: 500px;">
                    <table class="table table-hover mb-0 text-center small align-middle">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>작성일</th>
                                <th>제목</th>
                                <th>금액</th>
                                <th>관리</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var report in reportHistory)
                            {
                                <tr class="@(CurrentReport.Id == report.Id ? "table-active" : "")" style="cursor:pointer" @onclick="() => LoadReport(report)">
                                    <td>@report.Date.ToString("MM-dd")</td>
                                    <td class="text-start">@report.Title</td>
                                    <td class="text-end fw-bold text-danger">@report.TotalAmount.ToString("N0")</td>
                                    <td>
                                        <button class="btn btn-sm btn-link text-danger p-0" @onclick:stopPropagation="true" @onclick="() => DeleteReport(report)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!reportHistory.Any())
                            {
                                <tr><td colspan="4" class="py-4 text-muted">신청 내역이 없습니다.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* [3] 실제 출력 영역 (A4) *@
<div class="report-paper bg-white shadow mx-auto p-5" id="printable-area">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-decoration-underline" style="letter-spacing: 10px;">지출결의서</h1>
        <div class="text-end mt-3">
            @* 인쇄 시에는 저장된 날짜, 작성 중일 땐 오늘 날짜 *@
            <span class="fw-bold">작성일: @(CurrentReport.Id > 0 ? CurrentReport.Date.ToString("yyyy년 MM월 dd일") : DateTime.Now.ToString("yyyy년 MM월 dd일"))</span>
        </div>
    </div>

    @* 결재란 *@
    <div class="d-flex justify-content-end mb-4">
        <table class="table-bordered border-dark text-center" style="width: 350px;">
            <tr>
                <td rowspan="2" class="p-2 fw-bold bg-light" style="width: 50px;">결<br>재</td>
                <td style="width: 100px; font-size: 0.85rem;">팀 장</td>
                <td style="width: 100px; font-size: 0.85rem;">국 장</td>
                <td style="width: 100px; font-size: 0.85rem;">부 장</td>
            </tr>
            <tr style="height: 65px;"><td></td><td></td><td></td></tr>
        </table>
    </div>

    <div class="mb-4 border-bottom border-2 border-dark pb-2">
        <h5 class="fw-bold mb-1">부 서 명 : @CurrentUser?.Department</h5>
        <h5 class="fw-bold mb-0">제 &nbsp; &nbsp; 목 : @CurrentReport.Title</h5>
    </div>

    <table class="table table-bordered border-dark align-middle text-center mb-4">
        <thead class="table-light border-dark">
            <tr>
                <th style="width: 25%;">지출항목</th>
                <th style="width: 45%;">산출근거</th>
                <th style="width: 20%;">금액</th>
                <th style="width: 10%;">비고</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in itemList)
            {
                <tr>
                    <td class="fw-bold">@item.Category</td>
                    <td class="text-start ps-3">@item.CalcDetail</td>
                    <td class="text-end pe-3 fw-bold">@item.Amount.ToString("N0")</td>
                    <td class="no-print-col">
                        <button class="btn btn-sm text-danger border-0 bg-transparent no-print" @onclick="() => RemoveItem(item)">x</button>
                    </td>
                </tr>
            }
            @* 빈 줄 채우기 (출력 시 모양 유지용) *@
            @for (int i = 0; i < Math.Max(0, 5 - itemList.Count); i++)
            {
                <tr><td>&nbsp;</td><td></td><td></td><td></td></tr>
            }
        </tbody>
        <tfoot class="table-secondary border-dark fw-bold">
            <tr>
                <td colspan="2">합 계</td>
                <td class="text-end pe-3 text-primary">@CurrentRequestTotal.ToString("N0")</td>
                <td></td>
            </tr>
        </tfoot>
    </table>

    <div class="mt-5">
        <p class="mb-1">위와 같이 지출하고자 하오니 결재하여 주시기 바랍니다.</p>
        <h4 class="text-center mt-5 fw-bold" style="font-size: 1.5rem;">인천중앙교회 교육국 @CurrentUser?.Department</h4>
    </div>
</div>

<style>
    /* 화면 스타일 */
    .report-paper {
        width: 210mm;
        min-height: 297mm;
        font-family: 'Malgun Gothic', 'Dotum', sans-serif;
    }

    /* 인쇄 스타일 */
    @@media print {
        /* 1. 상단 메뉴, 사이드바, 입력 폼 등 모든 불필요 요소 숨김 */
        .no-print, .sidebar, header, nav, .btn, .alert {
            display: none !important;
        }
        /* 2. 배경 및 레이아웃 초기화 */
        body {
            background: white !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        /* 3. 출력 영역 설정 */
        #printable-area {
            display: block !important;
            width: 100% !important;
            margin: 0 !important;
            padding: 10mm !important;
            box-shadow: none !important;
            border: none !important;
        }
        /* 4. 테이블 색상 강제 출력 (브라우저 설정 무시 시도) */
        .table-light {
            background-color: #f8f9fa !important;
            -webkit-print-color-adjust: exact;
        }

        .table-secondary {
            background-color: #e2e3e5 !important;
            -webkit-print-color-adjust: exact;
        }
    }
</style>

@code {
    [CascadingParameter] public User? CurrentUser { get; set; }

    private int TargetYear = DateTime.Now.Year;
    private decimal TotalBudget = 0; // 예산 (환경설정)
    private decimal UsedBudget = 0;  // 기사용액 (지출결의서 신청 기준)

    // 현재 작성 중인 데이터
    private ExpenseReport CurrentReport = new() { Date = DateTime.Now };
    private List<BudgetPlan> itemList = new(); // 상세 내역 (메모리상)
    private BudgetPlan newItem = new();

    private List<ExpenseReport> reportHistory = new();
    private List<string> catList = new();

    private decimal CurrentRequestTotal => itemList.Sum(x => x.Amount);

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser == null) return;
        await LoadData();
        catList = await AccService.GetCategorySuggestionsAsync(CurrentUser.Department, "Expense");
    }

    private async Task LoadData()
    {
        // 1. 보조금 현황 (예산 vs 결의서)
        var status = await AccService.GetSubsidyStatusForReportAsync(CurrentUser.Department, TargetYear);
        TotalBudget = status.TotalReceived;
        UsedBudget = status.TotalUsed;

        // 2. 히스토리 로드
        reportHistory = await AccService.GetExpenseReportsAsync(CurrentUser.Department, TargetYear);
    }

    private void NewReport()
    {
        CurrentReport = new ExpenseReport { Date = DateTime.Now, Department = CurrentUser.Department, FiscalYear = TargetYear };
        itemList.Clear();
        newItem = new();
    }

    private void AddItem()
    {
        if (string.IsNullOrWhiteSpace(newItem.Category) || newItem.Amount <= 0) return;

        // *잔액 체크 (기사용액 + 현재 작성중 금액)*
        if (UsedBudget + CurrentRequestTotal + newItem.Amount > TotalBudget)
        {
            JSRuntime.InvokeVoidAsync("alert", "예산 잔액을 초과합니다.");
            return;
        }

        itemList.Add(new BudgetPlan { Category = newItem.Category, CalcDetail = newItem.CalcDetail, Amount = newItem.Amount });
        newItem.CalcDetail = ""; newItem.Amount = 0; // 초기화
    }

    private void RemoveItem(BudgetPlan item) => itemList.Remove(item);

    private async Task SaveReport()
    {
        if (!itemList.Any()) { await JSRuntime.InvokeVoidAsync("alert", "내역을 입력하세요."); return; }
        if (string.IsNullOrWhiteSpace(CurrentReport.Title)) { await JSRuntime.InvokeVoidAsync("alert", "제목을 입력하세요."); return; }

        // 데이터 매핑
        CurrentReport.Department = CurrentUser.Department;
        CurrentReport.FiscalYear = TargetYear;
        CurrentReport.TotalAmount = CurrentRequestTotal;
        CurrentReport.DetailsJson = JsonSerializer.Serialize(itemList); // 상세내역 JSON 변환

        await AccService.SaveExpenseReportAsync(CurrentReport);
        await LoadData(); // 잔액 및 히스토리 갱신
        await JSRuntime.InvokeVoidAsync("alert", "저장되었습니다.");

        // 신규 모드로 유지할지, 저장된 상태로 둘지 선택 (여기선 유지)
    }

    private void LoadReport(ExpenseReport report)
    {
        CurrentReport = new ExpenseReport
        {
            Id = report.Id,
            Date = report.Date,
            Title = report.Title,
            FiscalYear = report.FiscalYear,
            Department = report.Department,
            TotalAmount = report.TotalAmount
        };

        // JSON -> List 복원
        try { itemList = JsonSerializer.Deserialize<List<BudgetPlan>>(report.DetailsJson) ?? new(); }
        catch { itemList = new(); }
    }

    private async Task DeleteReport(ExpenseReport report)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "정말 삭제하시겠습니까? (잔액이 복구됩니다)"))
        {
            await AccService.DeleteExpenseReportAsync(report.Id);
            await LoadData();
            NewReport();
        }
    }

    private void EnterKey(KeyboardEventArgs e) { if (e.Key == "Enter") AddItem(); }
}