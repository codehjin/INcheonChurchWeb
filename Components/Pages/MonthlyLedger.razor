@page "/monthly"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@using INcheonChurchWeb.Data
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization
@inject AccountingService Accounting
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-calendar-check me-2"></i>월별 재정 장부</h3>

        @* 엑셀 다운로드 버튼 *@
        <button class="btn btn-success btn-sm" @onclick="DownloadExcel">
            <i class="bi bi-file-earmark-excel me-1"></i> 엑셀 다운로드
        </button>
    </div>

    @* ========================================================= *@
    @* [1] 날짜 이동 네비게이션 (화살표 기능 완벽 구현) *@
    @* ========================================================= *@
    <div class="card p-3 mb-4 bg-light shadow-sm border-0">
        <div class="row g-3 align-items-center text-center">

            @* 1. 연도 이동 *@
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">회계연도</label>
                <div class="d-flex justify-content-center align-items-center gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeYear(-1)">◀</button>
                    <span class="fw-bold fs-5">@CurrentYear 년</span>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeYear(1)">▶</button>
                </div>
            </div>

            @* 2. 월 이동 (12월에서 넘어가면 연도 자동 변경) *@
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">월 선택</label>
                <div class="d-flex justify-content-center align-items-center gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeMonth(-1)">◀</button>
                    <select class="form-select form-select-sm w-auto fw-bold text-center" @onchange="OnMonthChanged" value="@CurrentMonth">
                        <option value="0">전체 보기</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">@i 월</option>
                        }
                    </select>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeMonth(1)">▶</button>
                </div>
            </div>

            @* 3. 분기 이동 *@
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">분기 선택</label>
                <div class="d-flex justify-content-center align-items-center gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeQuarter(-1)">◀</button>
                    <select class="form-select form-select-sm w-auto fw-bold text-center" @onchange="OnQuarterChanged" value="@CurrentQuarter">
                        <option value="0">전체 분기</option>
                        <option value="1">1분기 (1~3월)</option>
                        <option value="2">2분기 (4~6월)</option>
                        <option value="3">3분기 (7~9월)</option>
                        <option value="4">4분기 (10~12월)</option>
                    </select>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeQuarter(1)">▶</button>
                </div>
            </div>

            @* 부서 표시 *@
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">부서</label>
                <div class="fw-bold text-primary fs-5">@UserDepartment</div>
            </div>
        </div>
    </div>

    @* ========================================================= *@
    @* [2] 장부 테이블 (잔액 컬럼 추가됨) *@
    @* ========================================================= *@
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-light text-secondary">
                    <tr>
                        <th style="width: 10%">날짜</th>
                        <th style="width: 8%">구분</th>
                        <th style="width: 12%">항목</th>
                        <th class="text-start">적요</th>
                        <th class="text-start" style="width: 15%">비고(거래처)</th>
                        <th class="text-end" style="width: 10%">수입</th>
                        <th class="text-end" style="width: 10%">지출</th>
                        <th class="text-end table-active" style="width: 10%">잔액</th> @* 잔액 컬럼 *@
                        <th style="width: 8%">관리</th>
                    </tr>
                </thead>
                <tbody>
                    @* 1. 이월금 표시 *@
                    <tr class="table-warning fw-bold">
                        <td>@CurrentYear-01-01</td>
                        <td><span class="badge bg-warning text-dark">이월</span></td>
                        <td>전년도이월</td>
                        <td class="text-start">기초 잔액</td>
                        <td></td>
                        <td class="text-end">@CarryOverAmount.ToString("N0")</td>
                        <td class="text-end">-</td>
                        <td class="text-end table-active text-primary">@CarryOverAmount.ToString("N0")</td>
                        <td></td>
                    </tr>

                    @* 2. 거래 내역 반복 *@
                    @{
                        decimal runningBalance = CarryOverAmount; // 누적 잔액 계산용 변수
                    }

                    @if (Entries != null && Entries.Any())
                    {
                        @foreach (var item in Entries)
                        {
                            // 잔액 계산: 수입이면 더하고, 지출이면 뺌
                            runningBalance += (item.Income - item.Expense);

                            <tr>
                                <td>@item.Date.ToString("MM-dd")</td>
                                <td>
                                    @if (item.Type == "수입")
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary">수입</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-danger bg-opacity-10 text-danger">지출</span>
                                    }
                                </td>
                                <td class="fw-bold text-secondary">@item.Category</td>
                                <td class="text-start">@item.Description</td>
                                <td class="text-start small text-muted">@item.Note</td>
                                <td class="text-end text-primary">@((item.Income > 0) ? item.Income.ToString("N0") : "")</td>
                                <td class="text-end text-danger">@((item.Expense > 0) ? item.Expense.ToString("N0") : "")</td>

                                @* 실시간 잔액 표시 (마이너스면 빨간색) *@
                                <td class="text-end table-active fw-bold @(runningBalance < 0 ? "text-danger" : "text-dark")">
                                    @runningBalance.ToString("N0")
                                </td>

                                <td>
                                    <button class="btn btn-outline-danger btn-sm py-0" @onclick="() => DeleteEntry(item.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-muted py-4">거래 내역이 없습니다.</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light fw-bold border-top">
                    <tr style="font-size: 1.1em;">
                        <td colspan="5" class="text-center">합 계</td>
                        <td class="text-end text-primary">@TotalIncome.ToString("N0")</td>
                        <td class="text-end text-danger">@TotalExpense.ToString("N0")</td>
                        @* 최종 잔액 *@
                        <td class="text-end @(runningBalance < 0 ? "text-danger" : "text-primary")">
                            @runningBalance.ToString("N0")
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }

    // 네비게이션용 변수 (화면에서 쓰던 이름들과 똑같이 만듦)
    private int CurrentYear = DateTime.Now.Year;
    private int CurrentMonth = DateTime.Now.Month;
    private int CurrentQuarter = 0; // 0이면 전체보기

    private string UserDepartment = "";
    private List<LedgerEntry> Entries = new();

    // 금액 변수들
    private decimal CarryOverAmount = 0; // 이월금
    private decimal TotalIncome = 0;
    private decimal TotalExpense = 0;

    protected override async Task OnInitializedAsync()
    {
        if (authenticationStateTask != null)
        {
            var authState = await authenticationStateTask;
            var user = authState.User;
            if (user.Identity != null && user.Identity.IsAuthenticated)
            {
                UserDepartment = user.FindFirst("Department")?.Value ?? "";
                await LoadData();
            }
        }
    }

    // 데이터 불러오기 로직
    private async Task LoadData()
    {
        if (string.IsNullOrEmpty(UserDepartment)) return;

        // 1. 해당 연도의 모든 데이터 가져오기 (이월금 계산을 위해)
        var allData = await Accounting.GetLedgerAsync(UserDepartment, CurrentYear);

        // 2. 기초 이월금 가져오기 (예산 계획에서 '이월금' 항목)
        // (만약 예산에 없으면 0원 처리)
        var budgetPlans = await Accounting.GetBudgetPlansAsync(UserDepartment, CurrentYear, "Income");
        CarryOverAmount = budgetPlans.FirstOrDefault(b => b.Category == "이월금")?.Amount ?? 0;

        // 3. 필터링 (월 또는 분기 선택에 따라)
        IEnumerable<LedgerEntry> query = allData;

        if (CurrentQuarter > 0) // 분기 선택 시
        {
            query = query.Where(x => x.Quarter == CurrentQuarter);
            CurrentMonth = 0; // 월 선택 초기화
        }
        else if (CurrentMonth > 0) // 월 선택 시
        {
            query = query.Where(x => x.Date.Month == CurrentMonth);
        }

        // 4. 결과 리스트 저장
        Entries = query.OrderBy(x => x.Date).ToList();

        // 5. 화면 표시용 합계 계산 (이월금 포함 X, 순수 수입/지출 합계)
        TotalIncome = Entries.Sum(x => x.Income);
        TotalExpense = Entries.Sum(x => x.Expense);
    }

    // =========================================================
    // [화살표 버튼 동작 로직]
    // =========================================================

    private async Task ChangeYear(int value)
    {
        CurrentYear += value;
        await LoadData();
    }

    private async Task ChangeMonth(int value)
    {
        CurrentMonth += value;

        // 12월 -> 1월 (내년으로)
        if (CurrentMonth > 12)
        {
            CurrentMonth = 1;
            CurrentYear++;
        }
        // 1월 -> 12월 (작년으로)
        else if (CurrentMonth < 1)
        {
            CurrentMonth = 12;
            CurrentYear--;
        }

        CurrentQuarter = 0; // 월을 바꾸면 분기 선택은 해제
        await LoadData();
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int m))
        {
            CurrentMonth = m;
            CurrentQuarter = 0;
            await LoadData();
        }
    }

    private async Task ChangeQuarter(int value)
    {
        CurrentQuarter += value;

        // 4분기 -> 1분기 (내년)
        if (CurrentQuarter > 4)
        {
            CurrentQuarter = 1;
            CurrentYear++;
        }
        // 1분기 -> 4분기 (작년)
        else if (CurrentQuarter < 1)
        {
            CurrentQuarter = 4;
            CurrentYear--;
        }

        CurrentMonth = 0; // 분기를 바꾸면 월 선택은 해제
        await LoadData();
    }

    private async Task OnQuarterChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int q))
        {
            CurrentQuarter = q;
            CurrentMonth = 0;
            await LoadData();
        }
    }

    // 삭제 기능
    private async Task DeleteEntry(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "정말 삭제하시겠습니까?"))
        {
            await Accounting.DeleteLedgerEntryAsync(id);
            await LoadData();
        }
    }

    // 엑셀 다운로드 (JS 호출)
    private async Task DownloadExcel()
    {
        await JSRuntime.InvokeVoidAsync("alert", "엑셀 다운로드 기능은 준비 중입니다.");
    }
}