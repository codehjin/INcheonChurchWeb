@page "/monthly"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@inject AccountingService AccService
@inject IJSRuntime JSRuntime
@inject NavigationManager Nav

<div class="container-fluid mt-3">

    @* [1] 상단 요약 카드 (필터링된 결과 기준 실시간 반영) *@
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card bg-primary text-white p-3 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 opacity-75">총 수입</h6>
                        <h3 class="fw-bold mb-0">@FilteredTransactions.Sum(t => t.Income).ToString("N0") <small class="fs-6">원</small></h3>
                    </div>
                    <i class="bi bi-graph-up-arrow fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white p-3 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 opacity-75">총 지출</h6>
                        <h3 class="fw-bold mb-0">@FilteredTransactions.Sum(t => t.Expense).ToString("N0") <small class="fs-6">원</small></h3>
                    </div>
                    <i class="bi bi-graph-down-arrow fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white p-3 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 opacity-75">잔액 (수입-지출)</h6>
                        <h3 class="fw-bold mb-0">@((FilteredTransactions.Sum(t => t.Income) - FilteredTransactions.Sum(t => t.Expense)).ToString("N0")) <small class="fs-6">원</small></h3>
                    </div>
                    <i class="bi bi-wallet2 fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    @* [2] 통합 컨트롤 패널: 기간 조회 + 필터 + 관리 기능 *@
    <div class="card p-3 mb-3 bg-light border-0 shadow-sm">

        @* (A) 상단줄: 기간 조회 및 부서 선택 *@
        <div class="d-flex flex-wrap gap-3 align-items-center justify-content-between mb-3 border-bottom pb-3">
            <div class="d-flex gap-2 align-items-center">
                @if (CurrentUser?.Role == "Admin")
                {
                    <select class="form-select form-select-sm w-auto fw-bold border-dark" @bind="SelectedDept">
                        <option value="">부서 선택</option>
                        @foreach (var d in new[] { "영유아부", "유치부", "유년부", "초등부", "중고등부", "교회학교운영팀" })
                        {
                            <option value="@d">@d</option>
                        }
                    </select>
                    <div class="vr mx-2"></div>
                }

                <div class="d-flex align-items-center">
                    <input type="number" class="form-control form-control-sm w-auto fw-bold" @bind="CurrentYear" />
                    <span class="ms-1 small text-muted">년</span>
                </div>

                <div class="btn-group btn-group-sm" role="group">
                    <input type="radio" class="btn-check" name="viewMode" id="vMonth" checked="@(ViewMode == "Month")" @onchange='() => ChangeMode("Month")'>
                    <label class="btn btn-outline-primary" for="vMonth">월별</label>

                    <input type="radio" class="btn-check" name="viewMode" id="vQuarter" checked="@(ViewMode == "Quarter")" @onchange='() => ChangeMode("Quarter")'>
                    <label class="btn btn-outline-primary" for="vQuarter">분기별</label>

                    <input type="radio" class="btn-check" name="viewMode" id="vYear" checked="@(ViewMode == "Year")" @onchange='() => ChangeMode("Year")'>
                    <label class="btn btn-outline-primary" for="vYear">년도</label>
                </div>

                @if (ViewMode == "Month")
                {
                    <select class="form-select form-select-sm w-auto" @bind="CurrentValue">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">@i 월</option>
                        }
                    </select>
                }
                else if (ViewMode == "Quarter")
                {
                    <select class="form-select form-select-sm w-auto" @bind="CurrentValue">
                        <option value="1">1분기</option>
                        <option value="2">2분기</option>
                        <option value="3">3분기</option>
                        <option value="4">4분기</option>
                    </select>
                }

                <button class="btn btn-sm btn-dark px-3 fw-bold" @onclick="LoadData">
                    <i class="bi bi-search me-1"></i>조회
                </button>
            </div>
        </div>

        @* (B) 하단줄: 데이터 필터링 및 일괄 작업 *@
        <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
            <div class="d-flex gap-2 align-items-center">
                <span class="badge bg-secondary">필터</span>
                <select class="form-select form-select-sm w-auto" @bind="FilterType">
                    <option value="">전체 구분</option>
                    <option value="수입">수입</option>
                    <option value="지출">지출</option>
                </select>
                <select class="form-select form-select-sm w-auto" @bind="FilterCategory">
                    <option value="">전체 항목</option>
                    @foreach (var cat in CategoryList)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>

            @* 일괄 작업 (선택된 항목이 있을 때만 표시) *@
            @if (selectedIds.Count > 0)
            {
                <div class="d-flex gap-2 align-items-center bg-white p-1 ps-3 pe-2 rounded border border-warning shadow-sm animate__animated animate__fadeIn">
                    <span class="fw-bold text-warning small">@selectedIds.Count 개 선택됨</span>
                    <select class="form-select form-select-sm w-auto border-warning" @bind="BulkTargetCategory">
                        <option value="">변경할 항목 선택...</option>
                        @foreach (var cat in CategoryList)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-warning fw-bold text-dark" @onclick="ApplyBulkUpdate">
                        <i class="bi bi-check-circle-fill me-1"></i>일괄 변경
                    </button>
                </div>
            }
        </div>
    </div>

    @* [3] 장부 테이블 *@
    <div class="table-responsive bg-white shadow-sm rounded" style="min-height: 500px;">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-dark text-center sticky-top">
                <tr>
                    <th width="40" class="bg-dark text-white">
                        <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" checked="@IsAllSelected" />
                    </th>
                    <th width="100">날짜</th>
                    <th width="80">구분</th>
                    <th width="150">항목</th>
                    <th>적요</th>
                    <th width="100">수입</th>
                    <th width="100">지출</th>
                    @if (CurrentUser?.Role != "Admin")
                    {
                        <th width="100">관리</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in FilteredTransactions)
                {
                    @if (editingId == item.Id)
                    {
                        <tr class="table-warning">
                            <td class="text-center"><i class="bi bi-pencil-fill text-muted"></i></td>
                            <td><input type="date" class="form-control form-control-sm" @bind="editItem.Date" /></td>
                            <td>
                                <select class="form-select form-select-sm" @bind="editItem.Type">
                                    <option>수입</option>
                                    <option>지출</option>
                                </select>
                            </td>
                            <td>
                                @* 수정 시 드롭다운 제공 *@
                                <select class="form-select form-select-sm" @bind="editItem.Category">
                                    @foreach (var c in CategoryList)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                </select>
                            </td>
                            <td><input class="form-control form-control-sm" @bind="editItem.Description" /></td>
                            <td><input type="number" class="form-control form-control-sm" @bind="editItem.Income" disabled="@(editItem.Type == "지출")" /></td>
                            <td><input type="number" class="form-control form-control-sm" @bind="editItem.Expense" disabled="@(editItem.Type == "수입")" /></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-success me-1" @onclick="SaveEdit"><i class="bi bi-check"></i></button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelEdit"><i class="bi bi-x"></i></button>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr class="@(selectedIds.Contains(item.Id) ? "table-active" : "")">
                            <td class="text-center">
                                <input type="checkbox" class="form-check-input" checked="@selectedIds.Contains(item.Id)" @onchange="() => ToggleSelection(item.Id)" />
                            </td>
                            <td class="text-center">@item.Date.ToString("MM-dd")</td>
                            <td class="text-center">
                                <span class="badge @(item.Type == "수입" ? "bg-primary" : "bg-danger")">@item.Type</span>
                            </td>
                            <td class="text-center fw-bold text-secondary">@item.Category</td>
                            <td>
                                @item.Description
                                @if (!string.IsNullOrEmpty(item.ReceiptPath))
                                {
                                    <i class="bi bi-paperclip text-primary ms-1" title="영수증 있음"></i>
                                }
                            </td>
                            <td class="text-end text-primary">@((item.Income > 0) ? item.Income.ToString("N0") : "-")</td>
                            <td class="text-end text-danger">@((item.Expense > 0) ? item.Expense.ToString("N0") : "-")</td>

                            @if (CurrentUser?.Role != "Admin")
                            {
                                <td class="text-center">
                                    <button class="btn btn-sm btn-link text-decoration-none p-0 me-2" @onclick="() => StartEdit(item)">✏️</button>
                                    <button class="btn btn-sm btn-link text-decoration-none p-0 text-danger" @onclick="() => DeleteItem(item)">🗑️</button>
                                </td>
                            }
                        </tr>
                    }
                }
                @if (!FilteredTransactions.Any())
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted">조건에 맞는 내역이 없습니다.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [CascadingParameter] public User? CurrentUser { get; set; }

    // 조회 조건 변수
    private int CurrentYear = DateTime.Now.Year;
    private string ViewMode = "Month"; // Month, Quarter, Year
    private int CurrentValue = DateTime.Now.Month; // 월 또는 분기 값
    private string SelectedDept = "";

    // 데이터
    private List<LedgerEntry> RawTransactions = new();
    private List<string> CategoryList = new();

    // 필터 & 선택 변수
    private string FilterType = "";
    private string FilterCategory = "";
    private HashSet<int> selectedIds = new();
    private string BulkTargetCategory = "";

    // 수정용 변수
    private int editingId = -1;
    private LedgerEntry editItem = new();

    // 필터 적용된 목록
    private IEnumerable<LedgerEntry> FilteredTransactions => RawTransactions
        .Where(t => string.IsNullOrEmpty(FilterType) || t.Type == FilterType)
        .Where(t => string.IsNullOrEmpty(FilterCategory) || t.Category == FilterCategory);

    private bool IsAllSelected => FilteredTransactions.Any() && selectedIds.Count == FilteredTransactions.Count();

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser == null) return;
        SelectedDept = CurrentUser.Department;
        await LoadData();
    }

    private async Task ChangeMode(string mode)
    {
        ViewMode = mode;
        if (mode == "Quarter") CurrentValue = 1;
        else if (mode == "Month") CurrentValue = DateTime.Now.Month;
        await LoadData();
    }

    private async Task LoadData()
    {
        string targetDept = (CurrentUser.Role == "Admin" && !string.IsNullOrEmpty(SelectedDept)) ? SelectedDept : CurrentUser.Department;

        // ★ [핵심] 서비스의 확장된 기간별 조회 메서드 사용
        // (Services/AccountingService.cs에 GetLedgerByOptionAsync가 구현되어 있어야 함)
        RawTransactions = await AccService.GetLedgerByOptionAsync(targetDept, CurrentYear, ViewMode, CurrentValue);

        // 항목 리스트 조회 (드롭다운용)
        CategoryList = await AccService.GetAllCategoriesAsync(targetDept);

        // 상태 초기화
        selectedIds.Clear();
        editingId = -1;
    }

    // --- 기능 로직들 ---
    private void ToggleSelection(int id)
    {
        if (selectedIds.Contains(id)) selectedIds.Remove(id); else selectedIds.Add(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false)) { foreach (var item in FilteredTransactions) selectedIds.Add(item.Id); }
        else selectedIds.Clear();
    }

    private async Task ApplyBulkUpdate()
    {
        if (string.IsNullOrEmpty(BulkTargetCategory) || selectedIds.Count == 0) return;
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"{selectedIds.Count}건을 '{BulkTargetCategory}'로 변경하시겠습니까?"))
        {
            await AccService.BulkUpdateCategoryAsync(selectedIds.ToList(), BulkTargetCategory);
            await LoadData();
            await JSRuntime.InvokeVoidAsync("alert", "변경되었습니다.");
        }
    }

    private void StartEdit(LedgerEntry item)
    {
        editingId = item.Id;
        editItem = new LedgerEntry
        {
            Id = item.Id,
            Date = item.Date,
            Type = item.Type,
            Category = item.Category,
            Description = item.Description,
            Income = item.Income,
            Expense = item.Expense,
            Department = item.Department,
            FiscalYear = item.FiscalYear,
            Note = item.Note ?? ""
        };
    }

    private async Task SaveEdit()
    {
        if (editItem.Type == "지출") editItem.Income = 0; else editItem.Expense = 0;
        await AccService.UpdateTransactionAsync(editItem);
        await LoadData();
    }

    private void CancelEdit() => editingId = -1;

    private async Task DeleteItem(LedgerEntry item)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "삭제하시겠습니까?"))
        {
            await AccService.DeleteTransactionAsync(item.Id);
            await LoadData();
        }
    }
}