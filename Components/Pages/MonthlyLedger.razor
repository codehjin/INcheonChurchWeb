@page "/monthly"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@using INcheonChurchWeb.Data
@using Microsoft.EntityFrameworkCore
@using ClosedXML.Excel
@using System.IO
@inject AccountingService Accounting
@inject AppDbContext DbContext
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<style>
    /* 화면용 테이블 스타일 (글자가 두 줄로 꺾이지 않도록 설정) */
    .table-fixed-layout {
        table-layout: fixed;
        word-break: break-all;
    }

        .table-fixed-layout th, .table-fixed-layout td {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    /* 인쇄(Print) 전용 최적화 스타일 */
    @@media print {
        .sidebar, .top-row, .btn, .no-print, .btn-group, select, .form-select, input, .form-control {
            display: none !important;
        }

        @@page {
            margin-top: 20mm !important;
            margin-bottom: 15mm !important;
            margin-left: 15mm !important;
            margin-right: 15mm !important;
        }

        body, .page, main, .content, .container {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            background-color: white !important;
            overflow: visible !important;
        }

        .page-break-before {
            page-break-before: always !important;
            break-before: page !important;
        }

        .print-only-title {
            display: block !important;
            text-align: center;
            margin-bottom: 15px;
            font-size: 22px;
            font-weight: bold;
        }

        thead th {
            text-align: center !important;
            vertical-align: middle !important;
            padding-top: 8px !important;
            padding-bottom: 8px !important;
        }

        table {
            page-break-inside: auto;
            border-collapse: collapse !important;
            margin-bottom: 0 !important;
            table-layout: fixed;
            word-break: break-all;
        }

            table td, table th {
                padding: 0.4rem 0.5rem !important;
                color: black !important;
                border-color: #444 !important;
                font-size: 0.95em !important;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

        tfoot {
            display: table-row-group !important;
        }

        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        .badge {
            border: 1px solid #000;
            color: #000 !important;
            background: none !important;
        }

        .print-income {
            background-color: #cfe2ff !important;
            color: #0d6efd !important;
            border: 1px solid #0d6efd !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .print-expense {
            background-color: #f8d7da !important;
            color: #dc3545 !important;
            border: 1px solid #dc3545 !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .hide-on-print {
            display: none !important;
        }
    }

    .print-only-title {
        display: none;
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 no-print">
        <h3 class="fw-bold text-primary"><i class="bi bi-calendar-check me-2"></i>월별 재정 장부</h3>
        <div class="btn-group shadow-sm">
            <button class="btn btn-secondary fw-bold" @onclick="PrintPage"><i class="bi bi-printer me-1"></i> 인쇄</button>
            <button class="btn btn-success fw-bold" @onclick="DownloadExcel"><i class="bi bi-file-earmark-excel me-1"></i> 엑셀 다운로드</button>
        </div>
    </div>

    <div class="card p-3 mb-3 bg-light shadow-sm border-0 no-print">
        <div class="row g-3 align-items-center text-center">
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">회계연도</label>
                <div class="d-flex justify-content-center align-items-center gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeYear(-1)">◀</button>
                    <span class="fw-bold fs-5">@CurrentYear 년</span>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeYear(1)">▶</button>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">월 선택</label>
                <div class="d-flex justify-content-center align-items-center gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeMonth(-1)">◀</button>
                    <select class="form-select form-select-sm w-auto fw-bold text-center" @onchange="OnMonthChanged" value="@CurrentMonth">
                        <option value="0">전체 보기</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i">@i 월</option>
                        }
                    </select>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ChangeMonth(1)">▶</button>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">분기 선택</label>
                <select class="form-select form-select-sm w-auto fw-bold text-center mx-auto" @onchange="OnQuarterChanged" value="@CurrentQuarter">
                    <option value="0">전체 분기</option>
                    <option value="1">1분기 (1~3월)</option>
                    <option value="2">2분기 (4~6월)</option>
                    <option value="3">3분기 (7~9월)</option>
                    <option value="4">4분기 (10~12월)</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">부서</label>
                @if (IsAdmin)
                {
                    <select class="form-select fw-bold text-primary border-primary" @onchange="OnDeptChanged" value="@SelectedDepartment">
                        <option value="">부서 전체보기</option>
                        @foreach (var dept in Departments)
                        {
                            <option value="@dept">@dept</option>
                        }
                    </select>
                }
                else
                {
                    <div class="fw-bold text-primary fs-5">
                        @(string.IsNullOrEmpty(SelectedDepartment) ? "로그인 필요" : SelectedDepartment)
                    </div>
                }
            </div>
        </div>
    </div>

    @if (!IsAdmin)
    {
        <div class="d-flex justify-content-between align-items-center mb-2 no-print bg-white p-2 rounded border shadow-sm">
            <div>
                <button class="btn btn-primary btn-sm fw-bold me-2" @onclick="ToggleAddForm">
                    <i class="bi bi-plus-lg me-1"></i>수동 건별 입력
                </button>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-secondary">@selectedIds.Count 선택됨</span>
                <select class="form-select form-select-sm w-auto fw-bold" @bind="bulkCategory">
                    <option value="">-- 일괄 변경할 카테고리 --</option>
                    <optgroup label="[수입]">@foreach (var c in IncomeCats) {
                    <option value="@c">@c</option>
                }
</optgroup>
                <optgroup label="[지출]">@foreach (var c in ExpenseCats) {
                <option value="@c">@c</option>
                                }
</optgroup>
            </select>
            <button class="btn btn-outline-success btn-sm fw-bold text-nowrap" @onclick="ApplyBulkEdit" disabled="@(selectedIds.Count == 0 || string.IsNullOrEmpty(bulkCategory))">
                <i class="bi bi-check-all"></i> 일괄수정
            </button>
            <button class="btn btn-danger btn-sm fw-bold text-nowrap ms-2" @onclick="DeleteSelected" disabled="@(selectedIds.Count == 0)">
                <i class="bi bi-trash-fill"></i> 일괄삭제
            </button>
        </div>
    </div>
        }

    @* 🚀 1. 현재 화면의 데이터만 반영하는 동적 자동완성 목록 (분류/적요) *@
    <datalist id="categoryList">
        @foreach (var cat in UniqueCategories)
        {
            <option value="@cat"></option>
        }
    </datalist>

    <datalist id="descriptionList">
        @foreach (var desc in UniqueDescriptions)
        {
            <option value="@desc"></option>
        }
    </datalist>

    @{
        if (!FilteredEntries.Any())
        {
            <div class="card shadow-sm border-0">
                <table class="table table-bordered mb-0">
                    <tr><td colspan="10" class="text-center text-muted py-5">조건에 맞는 내역이 없습니다.</td></tr>
                </table>
            </div>
        }
        else
        {
            var groupedByMonth = FilteredEntries.GroupBy(e => e.Date.Month).OrderBy(g => g.Key).ToList();
            bool isFirstGroup = true;

            foreach (var monthGroup in groupedByMonth)
            {
                int m = monthGroup.Key;
                decimal previousTotalIncome = Entries.Where(x => x.Date.Month < m).Sum(x => x.Income);
                decimal previousTotalExpense = Entries.Where(x => x.Date.Month < m).Sum(x => x.Expense);
                decimal startingBalanceForMonth = CarryOverAmount + previousTotalIncome - previousTotalExpense;

                decimal runningBalance = startingBalanceForMonth;
                decimal currentMonthIncome = 0;
                decimal currentMonthExpense = 0;

                string pageBreakClass = isFirstGroup ? "" : "page-break-before mt-5";
                isFirstGroup = false;

                <div class="@pageBreakClass">
                    <div class="print-only-title">
                        [ @CurrentYear 년 @(m)월 @(IsAdmin && string.IsNullOrEmpty(SelectedDepartment) ? "전체 부서 통합" : SelectedDepartment) 재정 장부 ]
                    </div>

                    <div class="card shadow-sm border-0 mb-4">
                        <div class="table-responsive" style="overflow-y:visible;">
                            <table class="table table-hover align-middle mb-0 text-center table-bordered table-fixed-layout">
                                <thead class="table-dark text-white text-center align-middle">
                                    <tr>
                                        @if (!IsAdmin)
                                        {
                                            <th style="width: 3%" class="hide-on-print"><input type="checkbox" class="form-check-input" @onchange="ToggleAll" checked="@IsAllSelected" /></th>
                                        }
                                        <th style="width: 7%">날짜</th>
                                        <th style="width: 7%">구분</th>
                                        <th style="width: 12%">분류항목</th>
                                        <th style="width: 30%">적요</th>
                                        <th style="width: 13%">비고</th>
                                        <th style="width: 8%">수입</th>
                                        <th style="width: 8%">지출</th>
                                        <th style="width: 8%">잔액</th>
                                        @if (!IsAdmin)
                                        {
                                            <th style="width: 10%" class="hide-on-print">관리</th>
                                        }
                                    </tr>

                                    <tr class="table-secondary hide-on-print">
                                        @if (!IsAdmin)
                                        {
                                            <th><i class="bi bi-funnel-fill text-muted"></i></th>
                                        }
                                        <th></th>
                                        <th>
                                            <select class="form-select form-select-sm" @bind="filterType" @bind:after="ApplyFilters">
                                                <option value="">전체</option>
                                                <option value="수입">수입</option>
                                                <option value="지출">지출</option>
                                            </select>
                                        </th>
                                        <th>
                                            <input type="text" class="form-control form-control-sm text-center"
                                                   list="categoryList" placeholder="검색"
                                                   @bind="filterCategory" @bind:event="oninput" autocomplete="off" />
                                        </th>
                                        <th>
                                            <input type="text" class="form-control form-control-sm text-center"
                                                   list="descriptionList" placeholder="검색"
                                                   @bind="filterDesc" @bind:event="oninput" autocomplete="off" />
                                        </th>
                                        <th colspan="5"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="table-warning fw-bold">
                                        @if (!IsAdmin)
                                        {
                                            <td class="hide-on-print"></td>
                                        }
                                        <td>-</td>
                                        <td><span class="badge bg-warning text-dark">이월</span></td>
                                        <td>전월이월</td>
                                        <td class="text-start">
                                            @if (IsAdmin && string.IsNullOrEmpty(SelectedDepartment))
                                            {
                                                <span class="badge bg-light text-dark border">통합 이월금</span>
                                            }
                                        </td>
                                        <td></td>
                                        <td class="text-end">@startingBalanceForMonth.ToString("N0")</td>
                                        <td class="text-end">-</td>
                                        <td class="text-end table-active text-primary">@startingBalanceForMonth.ToString("N0")</td>
                                        @if (!IsAdmin)
                                        {
                                            <td class="hide-on-print"></td>
                                        }
                                    </tr>

                                    @if (!IsAdmin && isAddingNew && currentMonthIncome == 0 && currentMonthExpense == 0)
                                    {
                                        <tr class="table-info hide-on-print">
                                            <td><span class="badge bg-primary">NEW</span></td>
                                            <td><input type="date" class="form-control form-control-sm px-1" @bind="newItem.Date" /></td>
                                            <td>
                                                <select class="form-select form-select-sm px-1" @bind="newItem.Type">
                                                    <option value="지출">지출</option>
                                                    <option value="수입">수입</option>
                                                </select>
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm px-1"
                                                       list="categoryList" placeholder="분류"
                                                       @bind="newItem.Category" autocomplete="off" />
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm px-1"
                                                       list="descriptionList" placeholder="적요"
                                                       @bind="newItem.Description" autocomplete="off" />
                                            </td>
                                            <td><input type="text" class="form-control form-control-sm px-1" placeholder="비고" @bind="newItem.Note" /></td>
                                            <td><input type="number" class="form-control form-control-sm px-1 text-end" @bind="newItem.Income" placeholder="0" /></td>
                                            <td><input type="number" class="form-control form-control-sm px-1 text-end" @bind="newItem.Expense" placeholder="0" /></td>
                                            <td class="table-active"></td>
                                            <td>
                                                <div class="d-flex gap-1 justify-content-center">
                                                    <button class="btn btn-success btn-sm py-0 fw-bold" @onclick="SaveNewEntry">[저장]</button>
                                                    <button class="btn btn-secondary btn-sm py-0 fw-bold" @onclick="() => isAddingNew = false">[취소]</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }

                                    @foreach (var item in monthGroup)
                                    {
                                        runningBalance += (item.Income - item.Expense);
                                        currentMonthIncome += item.Income;
                                        currentMonthExpense += item.Expense;
                                        bool isEditing = editingItemId == item.Id;

                                        <tr class="@(selectedIds.Contains(item.Id) ? "table-primary" : "")">
                                            @if (!IsAdmin)
                                            {
                                                <td class="hide-on-print">
                                                    <input type="checkbox" class="form-check-input" checked="@selectedIds.Contains(item.Id)" @onchange="@(e => ToggleSelection(item.Id, e))" />
                                                </td>
                                            }

                                            @if (!IsAdmin && isEditing && editBuffer != null)
                                            {
                                                <td><input type="date" class="form-control form-control-sm px-1" @bind="editBuffer.Date" /></td>
                                                <td>
                                                    <select class="form-select form-select-sm px-1" @bind="editBuffer.Type">
                                                        <option value="지출">지출</option>
                                                        <option value="수입">수입</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="text" class="form-control form-control-sm px-1"
                                                           list="categoryList" @bind="editBuffer.Category" autocomplete="off" />
                                                </td>
                                                <td>
                                                    <input type="text" class="form-control form-control-sm px-1"
                                                           list="descriptionList" @bind="editBuffer.Description" autocomplete="off" />
                                                </td>
                                                <td><input type="text" class="form-control form-control-sm px-1" @bind="editBuffer.Note" /></td>
                                                <td><input type="number" class="form-control form-control-sm px-1 text-end" @bind="editBuffer.Income" /></td>
                                                <td><input type="number" class="form-control form-control-sm px-1 text-end" @bind="editBuffer.Expense" /></td>
                                                <td class="text-end table-active fw-bold">@runningBalance.ToString("N0")</td>
                                                <td class="hide-on-print">
                                                    <div class="d-flex gap-1 justify-content-center">
                                                        <button class="btn btn-success btn-sm py-0 fw-bold" @onclick="SaveEdit">[저장]</button>
                                                        <button class="btn btn-secondary btn-sm py-0 fw-bold" @onclick="CancelEdit">[취소]</button>
                                                    </div>
                                                </td>
                                            }
                                            else
                                            {
                                                <td>@item.Date.ToString("MM-dd")</td>
                                                <td>
                                                    @if (item.Type == "수입")
                                                    {
                                                        <span class="badge bg-primary bg-opacity-10 text-primary print-income">수입</span>
                                                    }
                                                    else
                                                    {

                                                        <span class="badge bg-danger bg-opacity-10 text-danger print-expense">지출</span>
                                                    }
                                                </td>
                                                <td class="fw-bold" title="@item.Category">@item.Category</td>
                                                <td class="text-start" title="@item.Description">
                                                    @item.Description
                                                    @if (IsAdmin && string.IsNullOrEmpty(SelectedDepartment))
                                                    {
                                                        <span class="badge bg-light text-dark border ms-2">@item.Department</span>
                                                    }
                                                </td>
                                                <td class="text-start small text-muted" title="@item.Note">@item.Note</td>
                                                <td class="text-end text-primary">@((item.Income > 0) ? item.Income.ToString("N0") : "")</td>
                                                <td class="text-end text-danger">@((item.Expense > 0) ? item.Expense.ToString("N0") : "")</td>
                                                <td class="text-end table-active fw-bold">@runningBalance.ToString("N0")</td>

                                                @if (!IsAdmin)
                                                {
                                                    <td class="hide-on-print">
                                                        <div class="d-flex gap-1 justify-content-center">
                                                            <button class="btn btn-sm btn-outline-primary py-0 px-2 fw-bold" @onclick="() => StartEdit(item)">
                                                                [수정]
                                                            </button>
                                                            <button class="btn btn-sm btn-outline-danger py-0 px-2 fw-bold" @onclick="() => DeleteSingle(item.Id)">
                                                                [삭제]
                                                            </button>
                                                        </div>
                                                    </td>
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light fw-bold border-top">
                                    <tr style="font-size: 1.1em;">
                                        @if (!IsAdmin)
                                        {
                                            <td class="hide-on-print"></td>
                                        }
                                        <td colspan="5" class="text-center">@(m)월 계 (누계 잔액)</td>
                                        <td class="text-end text-primary">@currentMonthIncome.ToString("N0")</td>
                                        <td class="text-end text-danger">@currentMonthExpense.ToString("N0")</td>
                                        <td class="text-end text-primary">@runningBalance.ToString("N0")</td>
                                        @if (!IsAdmin)
                                        {
                                            <td class="hide-on-print"></td>
                                        }
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

<script>
    window.downloadExcelFile = (fileName, base64String) => {
        const link = document.createElement('a');
        link.download = fileName;
        link.href = `data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,${base64String}`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
</script>

@code {
    [CascadingParameter] public User? CurrentUser { get; set; }

    private int CurrentYear = DateTime.Now.Year;
    private int CurrentMonth = DateTime.Now.Month;
    private int CurrentQuarter = 0;

    private string SelectedDepartment = "";
    private bool IsAdmin = false;

    private List<LedgerEntry> Entries = new();
    private List<LedgerEntry> FilteredEntries = new();
    private decimal CarryOverAmount = 0;

    private decimal TotalIncome = 0;
    private decimal TotalExpense = 0;

    private readonly string[] Departments = new[] { "영유아부", "유치부", "유년부", "초등부", "중고등부", "교회학교운영팀" };
    private readonly string[] IncomeCats = new[] { "주일헌금", "찬조금", "이월금", "교회보조금", "은행이자", "회비수입", "기타수입" };
    private readonly string[] ExpenseCats = new[] { "행사비", "공과비", "교육활동비", "여름성경학교", "운영비", "간식비", "부서관리비", "교사회의비", "훈련비", "기타지출" };

    // 🚀 동적 리스트
    private List<string> UniqueDescriptions = new();
    private List<string> UniqueCategories = new();

    private string filterType = "";
    private string _filterCategory = "";
    private string filterCategory { get => _filterCategory; set { _filterCategory = value; ApplyFilters(); } }
    private string _filterDesc = "";
    private string filterDesc { get => _filterDesc; set { _filterDesc = value; ApplyFilters(); } }

    private HashSet<int> selectedIds = new();
    private bool IsAllSelected => FilteredEntries.Any() && selectedIds.Count == FilteredEntries.Count;
    private string bulkCategory = "";

    private bool isAddingNew = false;
    private LedgerEntry newItem = new LedgerEntry { Date = DateTime.Now, Type = "지출", Income = 0, Expense = 0 };

    private int? editingItemId = null;
    private LedgerEntry? editBuffer = null;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUser != null && !string.IsNullOrEmpty(CurrentUser.Department))
        {
            if (CurrentUser.Department == "교육국" || CurrentUser.Department == "관리자" || CurrentUser.Role == "Admin")
            {
                IsAdmin = true;
                SelectedDepartment = "";
            }
            else
            {
                IsAdmin = false;
                SelectedDepartment = CurrentUser.Department;
            }
            await LoadData();
        }
    }

    private async Task OnDeptChanged(ChangeEventArgs e) { SelectedDepartment = e.Value?.ToString() ?? ""; await LoadData(); }
    private async Task ChangeYear(int value) { CurrentYear += value; await LoadData(); }
    private async Task ChangeMonth(int value) { CurrentMonth += value; if (CurrentMonth > 12) { CurrentMonth = 1; CurrentYear++; } else if (CurrentMonth < 1) { CurrentMonth = 12; CurrentYear--; } CurrentQuarter = 0; await LoadData(); }
    private async Task OnMonthChanged(ChangeEventArgs e) { if (int.TryParse(e.Value?.ToString(), out int m)) { CurrentMonth = m; CurrentQuarter = 0; await LoadData(); } }
    private async Task OnQuarterChanged(ChangeEventArgs e) { if (int.TryParse(e.Value?.ToString(), out int q)) { CurrentQuarter = q; CurrentMonth = 0; await LoadData(); } }

    private async Task LoadData()
    {
        var query = DbContext.Transactions.AsNoTracking().Where(t => t.FiscalYear == CurrentYear);

        if (!string.IsNullOrEmpty(SelectedDepartment)) query = query.Where(t => t.Department == SelectedDepartment);

        var allYearData = await query.OrderBy(t => t.Date).ToListAsync();

        var budgetQuery = DbContext.BudgetPlans.AsNoTracking().Where(b => b.Year == CurrentYear);
        if (!string.IsNullOrEmpty(SelectedDepartment)) budgetQuery = budgetQuery.Where(b => b.Department == SelectedDepartment);
        var budgetPlans = await budgetQuery.ToListAsync();

        decimal baseCarryOver = budgetPlans.FirstOrDefault(b => b.Category.Contains("이월"))?.Amount ?? 0;

        var prevData = allYearData.Where(x => x.Date.Month < CurrentMonth).ToList();
        if (CurrentMonth == 0 && CurrentQuarter == 0) prevData.Clear();
        else if (CurrentQuarter > 0) prevData = allYearData.Where(x => x.Date.Month < ((CurrentQuarter - 1) * 3 + 1)).ToList();

        CarryOverAmount = baseCarryOver + prevData.Sum(x => x.Income) - prevData.Sum(x => x.Expense);

        IEnumerable<LedgerEntry> filteredQuery = allYearData;
        if (CurrentMonth > 0) filteredQuery = filteredQuery.Where(x => x.Date.Month == CurrentMonth);
        else if (CurrentQuarter > 0)
        {
            int startMonth = (CurrentQuarter - 1) * 3 + 1;
            filteredQuery = filteredQuery.Where(x => x.Date.Month >= startMonth && x.Date.Month <= startMonth + 2);
        }

        Entries = filteredQuery.ToList();
        TotalIncome = Entries.Sum(x => x.Income);
        TotalExpense = Entries.Sum(x => x.Expense);

        ApplyFilters();
        selectedIds.Clear();
    }

    private void ApplyFilters()
    {
        var temp = Entries.AsEnumerable();
        if (!string.IsNullOrEmpty(filterType)) temp = temp.Where(x => x.Type == filterType);
        if (!string.IsNullOrEmpty(filterCategory)) temp = temp.Where(x => x.Category.Contains(filterCategory, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(filterDesc)) temp = temp.Where(x => x.Description.Contains(filterDesc, StringComparison.OrdinalIgnoreCase));

        FilteredEntries = temp.ToList();

        // 🚀 2. 현재 화면의 데이터(Entries)에서만 카테고리와 적요를 동적으로 뽑아냅니다!
        UniqueDescriptions = Entries
            .Where(t => !string.IsNullOrWhiteSpace(t.Description))
            .Select(t => t.Description.Trim())
            .Distinct()
            .OrderBy(d => d)
            .ToList();

        UniqueCategories = Entries
            .Where(t => !string.IsNullOrWhiteSpace(t.Category))
            .Select(t => t.Category.Trim())
            .Distinct()
            .OrderBy(c => c)
            .ToList();
    }

    private void ToggleSelection(int id, ChangeEventArgs e) { if ((bool)(e.Value ?? false)) selectedIds.Add(id); else selectedIds.Remove(id); }
    private void ToggleAll(ChangeEventArgs e) { if ((bool)(e.Value ?? false)) { foreach (var item in FilteredEntries) selectedIds.Add(item.Id); } else selectedIds.Clear(); }

    private async Task DeleteSingle(int id)
    {
        var result = await JSRuntime.InvokeAsync<string>("prompt", "⚠️ [경고] 삭제 시 되돌릴 수 없습니다.\n정말 삭제하시려면 숫자 '1'을 입력하세요.");
        if (result != null && result.Trim() == "1")
        {
            var target = await DbContext.Transactions.FindAsync(id);
            if (target != null)
            {
                DbContext.Transactions.Remove(target);
                await DbContext.SaveChangesAsync();
                await LoadData();
            }
        }
        else if (result != null) { await JSRuntime.InvokeVoidAsync("alert", "숫자가 일치하지 않아 취소되었습니다."); }
    }

    private async Task DeleteSelected()
    {
        int count = selectedIds.Count;
        var result = await JSRuntime.InvokeAsync<string>("prompt", $"⚠️ [경고] 삭제 시 되돌릴 수 없습니다.\n선택한 {count}건을 일괄 삭제하시려면 숫자 '{count}'을(를) 입력하세요.");
        if (result != null && result.Trim() == count.ToString())
        {
            var targets = await DbContext.Transactions.Where(t => selectedIds.Contains(t.Id)).ToListAsync();
            DbContext.Transactions.RemoveRange(targets);
            await DbContext.SaveChangesAsync();
            await LoadData();
            await JSRuntime.InvokeVoidAsync("alert", $"{count}건 삭제 완료.");
        }
    }

    private void StartEdit(LedgerEntry item)
    {
        editingItemId = item.Id;
        editBuffer = new LedgerEntry { Id = item.Id, Date = item.Date, Type = item.Type, Category = item.Category, Description = item.Description, Note = item.Note, Income = item.Income, Expense = item.Expense, Department = item.Department, FiscalYear = item.FiscalYear, Quarter = item.Quarter };
    }

    private void CancelEdit() { editingItemId = null; editBuffer = null; }

    private async Task SaveEdit()
    {
        if (editBuffer != null)
        {
            var existing = await DbContext.Transactions.FindAsync(editBuffer.Id);
            if (existing != null)
            {
                existing.Date = editBuffer.Date;
                existing.Type = editBuffer.Type;
                existing.Category = editBuffer.Category;
                existing.Description = editBuffer.Description;
                existing.Note = editBuffer.Note;
                existing.Income = editBuffer.Income;
                existing.Expense = editBuffer.Expense;
                existing.Quarter = GetQuarter(editBuffer.Date);
                existing.FiscalYear = editBuffer.Date.Year;

                await DbContext.SaveChangesAsync();
            }
            editingItemId = null;
            await LoadData();
        }
    }

    private async Task ApplyBulkEdit()
    {
        if (selectedIds.Count > 0 && !string.IsNullOrEmpty(bulkCategory))
        {
            var targets = await DbContext.Transactions.Where(t => selectedIds.Contains(t.Id)).ToListAsync();
            foreach (var t in targets) t.Category = bulkCategory;

            await DbContext.SaveChangesAsync();

            bulkCategory = "";
            await LoadData();
            await JSRuntime.InvokeVoidAsync("alert", "일괄 수정 완료.");
        }
    }

    private void ToggleAddForm()
    {
        isAddingNew = !isAddingNew;
        if (isAddingNew) newItem = new LedgerEntry { Date = DateTime.Now, Type = "지출", Income = 0, Expense = 0, Department = SelectedDepartment, Category = "" };
    }

    private async Task SaveNewEntry()
    {
        if (string.IsNullOrWhiteSpace(newItem.Description)) { await JSRuntime.InvokeVoidAsync("alert", "적요를 입력해주세요."); return; }
        if (string.IsNullOrWhiteSpace(newItem.Category)) newItem.Category = "미분류";

        newItem.Department = SelectedDepartment;
        newItem.FiscalYear = newItem.Date.Year;
        newItem.Quarter = GetQuarter(newItem.Date);

        DbContext.Transactions.Add(newItem);
        await DbContext.SaveChangesAsync();
        isAddingNew = false;
        await LoadData();
    }

    private int GetQuarter(DateTime d) => d.Month switch { 12 or 1 or 2 => 1, 3 or 4 or 5 => 2, 6 or 7 or 8 => 3, _ => 4 };

    private async Task PrintPage() { await JSRuntime.InvokeVoidAsync("print"); }

    private async Task DownloadExcel()
    {
        try
        {
            using var workbook = new XLWorkbook();
            var allYearData = await DbContext.Transactions.AsNoTracking()
                .Where(t => t.FiscalYear == CurrentYear && (string.IsNullOrEmpty(SelectedDepartment) || t.Department == SelectedDepartment))
                .OrderBy(t => t.Date)
                .ToListAsync();

            var budgetQuery = DbContext.BudgetPlans.AsNoTracking().Where(b => b.Year == CurrentYear);
            if (!string.IsNullOrEmpty(SelectedDepartment)) budgetQuery = budgetQuery.Where(b => b.Department == SelectedDepartment);
            var budgetPlans = await budgetQuery.ToListAsync();

            List<int> targetMonths = new List<int>();
            string periodStr = "";

            if (CurrentMonth > 0) { targetMonths.Add(CurrentMonth); periodStr = $"{CurrentMonth:D2}월"; }
            else if (CurrentQuarter > 0) { int sm = (CurrentQuarter - 1) * 3 + 1; targetMonths.AddRange(new[] { sm, sm + 1, sm + 2 }); periodStr = $"{CurrentQuarter}분기"; }
            else { targetMonths.AddRange(Enumerable.Range(1, 12)); periodStr = "전체"; }

            decimal runningBal = budgetPlans.FirstOrDefault(b => b.Category.Contains("이월"))?.Amount ?? 0;

            for (int i = 1; i <= 12; i++)
            {
                var monthData = allYearData.Where(x => x.Date.Month == i).ToList();
                decimal prevBal = runningBal;

                foreach (var item in monthData) runningBal += (item.Income - item.Expense);

                if (!targetMonths.Contains(i)) continue;

                var ws = workbook.Worksheets.Add($"{CurrentYear}-{i:D2}");

                var headers = new[] { "날짜", "구분", "분류항목", "적요", "비고", "수입", "지출", "잔액" };
                for (int c = 0; c < headers.Length; c++)
                {
                    ws.Cell(1, c + 1).Value = headers[c];
                    ws.Cell(1, c + 1).Style.Fill.BackgroundColor = XLColor.LightGray;
                    ws.Cell(1, c + 1).Style.Font.Bold = true;
                    ws.Cell(1, c + 1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                }

                ws.Cell(2, 1).Value = "-";
                ws.Cell(2, 2).Value = "이월";
                ws.Cell(2, 3).Value = "전월이월";
                ws.Cell(2, 4).Value = "";
                ws.Cell(2, 6).Value = prevBal;
                ws.Cell(2, 8).Value = prevBal;

                ws.Column(6).Style.NumberFormat.Format = "#,##0";
                ws.Column(7).Style.NumberFormat.Format = "#,##0";
                ws.Column(8).Style.NumberFormat.Format = "#,##0";

                int row = 3;
                decimal mIncome = 0;
                decimal mExpense = 0;
                decimal currentSheetBal = prevBal;

                foreach (var item in monthData)
                {
                    currentSheetBal += (item.Income - item.Expense);
                    mIncome += item.Income;
                    mExpense += item.Expense;

                    ws.Cell(row, 1).Value = item.Date.ToString("yyyy-MM-dd");
                    ws.Cell(row, 2).Value = item.Type;
                    ws.Cell(row, 3).Value = item.Category;
                    ws.Cell(row, 4).Value = item.Description;
                    ws.Cell(row, 5).Value = item.Note;
                    ws.Cell(row, 6).Value = item.Income == 0 ? "" : item.Income;
                    ws.Cell(row, 7).Value = item.Expense == 0 ? "" : item.Expense;
                    ws.Cell(row, 8).Value = currentSheetBal;
                    row++;
                }

                ws.Cell(row, 1).Value = "월 계 (누계 잔액)";
                ws.Range(row, 1, row, 5).Merge();
                ws.Range(row, 1, row, 5).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                ws.Row(row).Style.Font.Bold = true;
                ws.Cell(row, 6).Value = mIncome;
                ws.Cell(row, 7).Value = mExpense;
                ws.Cell(row, 8).Value = currentSheetBal;

                ws.Column(1).Width = 12;
                ws.Column(2).Width = 8;
                ws.Column(3).Width = 15;
                ws.Column(4).Width = 35;
                ws.Column(5).Width = 15;
                ws.Column(6).Width = 12;
                ws.Column(7).Width = 12;
                ws.Column(8).Width = 12;

                ws.Column(1).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                ws.Column(2).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                ws.Column(3).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

                ws.Column(4).Style.Alignment.WrapText = false;
                ws.Column(5).Style.Alignment.WrapText = false;
            }

            if (workbook.Worksheets.Count == 0) workbook.Worksheets.Add("데이터없음");

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());

            string today = DateTime.Now.ToString("yyyyMMdd");
            string deptName = string.IsNullOrEmpty(SelectedDepartment) ? "전체부서" : SelectedDepartment;
            string fileName = $"{deptName}-{CurrentYear}년{periodStr}-{today}.xlsx";

            await JSRuntime.InvokeVoidAsync("downloadExcelFile", fileName, base64);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"엑셀 생성 오류: {ex.Message}");
        }
    }
