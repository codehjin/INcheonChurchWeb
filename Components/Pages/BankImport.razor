@page "/bank-import"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@using INcheonChurchWeb.Data
@using ExcelDataReader
@using System.Data
@using System.IO
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@inject AccountingService Accounting
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-bank me-2"></i>은행 거래내역 가져오기</h3>
        
        <button class="btn btn-outline-danger fw-bold shadow-sm" @onclick="ClearWorkData">
            <i class="bi bi-arrow-clockwise me-1"></i> 불러온 내역 초기화
        </button>
    </div>

    @if (!string.IsNullOrEmpty(UserDepartment))
    {
        <div class="alert alert-secondary shadow-sm">
            현재 <strong>'@UserDepartment'</strong> 장부로 기록됩니다.
            @if (UserDepartment == "유년부")
            { <span class="badge bg-success ms-2">자동 분류 적용됨</span> }
            else
            { <span class="badge bg-warning text-dark ms-2">수동 분류 모드</span> }
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card p-4 shadow-sm bg-light h-100 border-0">
                <h5 class="fw-bold mb-3">1. 엑셀 파일 선택</h5>
                <InputFile OnChange="LoadFiles" class="form-control mb-2" accept=".xls,.xlsx,.csv" />
                <div class="form-text text-muted">은행 엑셀 파일(.xls, .xlsx)을 업로드하세요.</div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4 shadow-sm h-100 border-primary border-opacity-25">
                <h5 class="fw-bold mb-3 text-primary">2. 기존 불러온 내역</h5>
                @if (LastTransactionDate.HasValue)
                {
                    <div class="fs-5">마지막 거래일: <strong class="text-success">@LastTransactionDate.Value.ToString("yyyy-MM-dd")</strong></div>
                    <div class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i> 이 날짜 이후의 내역만 업로드하세요.</div>
                }
                else
                {
                    <div class="text-muted"><i class="bi bi-exclamation-circle me-1"></i> 아직 기록된 내역이 없습니다.</div>
                }
            </div>
        </div>
    </div>

    @if (isLoading) { <div class="alert alert-info shadow-sm"><div class="spinner-border spinner-border-sm me-2"></div> 엑셀 파일 분석 중...</div> }
    @if (!string.IsNullOrEmpty(errorMessage)) { <div class="alert alert-danger shadow-sm">@errorMessage</div> }

    @if (_savedPreviewList != null && _savedPreviewList.Any())
    {
        var unclassifiedIncomeCount = _savedPreviewList.Count(x => x.Category == "미분류" && x.Type == "수입");
        var unclassifiedExpenseCount = _savedPreviewList.Count(x => x.Category == "미분류" && x.Type == "지출");
        var totalUnclassified = unclassifiedIncomeCount + unclassifiedExpenseCount;
        
        <div class="card shadow-sm border-0 mb-4 bg-light">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold text-dark mb-0">
                        <i class="bi bi-arrows-move text-primary me-2"></i> 퀵 분류 
                        <span class="fs-6 text-muted ms-2">(탭을 이동하며 드래그 또는 일괄 지정하세요)</span>
                    </h5>
                    <span class="badge bg-danger rounded-pill px-3 py-2 fs-6 shadow-sm">남은 미분류: @totalUnclassified 건</span>
                </div>

                <div class="row g-4">
                    <div class="col-md-5">
                        <div class="bg-white p-3 rounded border shadow-sm h-100">
                            
                            <ul class="nav nav-tabs mb-3" style="cursor:pointer;">
                                <li class="nav-item w-50 text-center">
                                    <a class="nav-link @(_savedCurrentTab == "수입" ? "active fw-bold text-primary border-primary border-bottom-0" : "text-muted")" 
                                       @onclick="@(() => ChangeTab("수입"))">
                                        💰 수입 (@unclassifiedIncomeCount)
                                    </a>
                                </li>
                                <li class="nav-item w-50 text-center">
                                    <a class="nav-link @(_savedCurrentTab == "지출" ? "active fw-bold text-danger border-danger border-bottom-0" : "text-muted")" 
                                       @onclick="@(() => ChangeTab("지출"))">
                                        💸 지출 (@unclassifiedExpenseCount)
                                    </a>
                                </li>
                            </ul>

                            <div class="mb-3 pb-3 border-bottom bg-light p-2 rounded">
                                <input type="text" class="form-control form-control-sm mb-2 border-0 shadow-sm" placeholder="🔍 텍스트 검색..." @bind="searchUnclassified" @bind:event="oninput" />
                                <div class="input-group input-group-sm shadow-sm">
                                    <select class="form-select fw-bold border-0" @bind="batchSelectedCategory">
                                        <option value="">(일괄 지정 카테고리 선택)</option>
                                        @if(_savedCurrentTab == "수입")
                                        {
                                            @foreach(var c in IncomeCats) { <option value="@c">@c</option> }
                                        }
                                        else
                                        {
                                            @foreach(var c in ExpenseCats) { <option value="@c">@c</option> }
                                        }
                                    </select>
                                    <button class="btn @(_savedCurrentTab == "수입" ? "btn-primary" : "btn-danger")" 
                                            @onclick="ApplyBatchToUnclassified" 
                                            disabled="@(selectedUnclassified.Count == 0 || string.IsNullOrEmpty(batchSelectedCategory))">
                                        <i class="bi bi-check2-all"></i> 적용 (@selectedUnclassified.Count)
                                    </button>
                                </div>
                            </div>

                            <div style="height: 380px; overflow-y: auto; padding-right: 5px;">
                                @{ var currentList = GetFilteredUnclassified(); }
                                
                                @if (!currentList.Any())
                                {
                                    <div class="text-center text-muted py-5 mt-4">
                                        <i class="bi bi-check-circle fs-1 text-success d-block mb-2"></i>
                                        @_savedCurrentTab 미분류가 모두 처리되었습니다!
                                    </div>
                                }
                                else
                                {
                                    <div class="text-end mb-2">
                                        <button class="btn btn-sm btn-link text-decoration-none p-0" @onclick="SelectAllCurrentTab">전체선택</button>
                                    </div>

                                    @foreach (var item in currentList)
                                    {
                                        <div class="card mb-2 border cursor-grab shadow-sm transition-all 
                                                    @(_savedCurrentTab == "수입" ? "border-primary border-opacity-50" : "border-danger border-opacity-50")
                                                    @(selectedUnclassified.Contains(item) ? (_savedCurrentTab == "수입" ? "bg-primary text-white" : "bg-danger text-white") : "bg-white")" 
                                             draggable="true" @ondragstart="@(() => HandleDragStart(item))" style="cursor: grab;">
                                            <div class="card-body p-2 d-flex align-items-center">
                                                <input type="checkbox" class="form-check-input me-3" style="transform: scale(1.3); cursor:pointer;" 
                                                       checked="@selectedUnclassified.Contains(item)" @onchange="@(e => ToggleUnclassified(item, e))" />
                                                <div class="flex-grow-1" @onclick="@(() => ToggleRowClick(item))" style="cursor:pointer;">
                                                    <small class="@(selectedUnclassified.Contains(item) ? "text-light" : "text-muted") d-block">@item.Date.ToString("MM-dd")</small>
                                                    <strong>@item.Description</strong>
                                                    <div class="text-end fw-bold">
                                                        @(_savedCurrentTab == "수입" ? $"+{item.Income:N0}" : $"-{item.Expense:N0}")
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-7">
                        <div class="bg-white p-3 rounded border shadow-sm h-100">
                            @if (_savedCurrentTab == "수입")
                            {
                                <div class="text-primary fw-bold mb-3 pb-2 border-bottom fs-5"><i class="bi bi-box-arrow-in-down me-2"></i>수입 전용 바구니</div>
                                <div class="row g-3">
                                    @foreach (var cat in IncomeCats)
                                    {
                                        <div class="col-4">
                                            <div class="card text-center py-4 border-primary shadow-sm drop-zone" 
                                                 style="background-color: @(draggedItem != null ? "#eef5ff" : "#fff"); transition: 0.2s;"
                                                 ondragover="event.preventDefault();" @ondrop="@(() => HandleDrop(cat))">
                                                <div class="card-body p-0"><strong class="text-primary fs-5">@cat</strong></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-danger fw-bold mb-3 pb-2 border-bottom fs-5"><i class="bi bi-cart-dash me-2"></i>지출 전용 바구니</div>
                                <div class="row g-3">
                                    @foreach (var cat in ExpenseCats)
                                    {
                                        <div class="col-4">
                                            <div class="card text-center py-4 border-danger shadow-sm drop-zone" 
                                                 style="background-color: @(draggedItem != null ? "#ffeef0" : "#fff"); transition: 0.2s;"
                                                 ondragover="event.preventDefault();" @ondrop="@(() => HandleDrop(cat))">
                                                <div class="card-body p-0"><strong class="text-danger">@cat</strong></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-end mb-2 mt-4 pt-2">
            <div>
                <h5 class="fw-bold mb-2">최종 장부 미리보기 (@_savedPreviewList.Count 건)</h5>
                <input type="text" class="form-control form-control-sm" placeholder="🔍 전체 내역 검색..." style="width: 250px;" @bind="searchPreview" @bind:event="oninput" />
            </div>
            
            <button class="btn btn-primary fw-bold px-4 py-2 shadow-sm" @onclick="SaveToLedger" disabled="@(isSaving || totalUnclassified > 0)">
                @if (isSaving) { <span><div class="spinner-border spinner-border-sm me-2"></div>저장 중...</span> }
                else if (totalUnclassified > 0) { <span>⚠️ 미분류 해결 필요 (@totalUnclassified)</span> }
                else { <span><i class="bi bi-floppy-fill me-2"></i>장부에 저장하기</span> }
            </button>
        </div>

        <div class="table-responsive shadow-sm bg-white rounded border" style="max-height: 500px; overflow-y: auto;">
            <table class="table table-hover align-middle mb-0 text-center sticky-top">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th style="width: 10%">날짜</th>
                        <th style="width: 8%">구분</th>
                        <th class="text-start">적요</th>
                        <th class="text-start">비고</th>
                        <th style="width: 10%">수입</th>
                        <th style="width: 10%">지출</th>
                        <th style="width: 15%">카테고리 수정</th>
                        <th style="width: 6%">삭제</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in GetFilteredPreview())
                    {
                        <tr class="@(item.Category == "미분류" ? "table-danger" : "")">
                            <td>@item.Date.ToString("MM-dd")</td>
                            <td>
                                @if(item.Type == "수입") { <span class="badge bg-primary bg-opacity-10 text-primary">수입</span> }
                                else { <span class="badge bg-danger bg-opacity-10 text-danger">지출</span> }
                            </td>
                            <td class="text-start">@item.Description</td>
                            <td class="text-start text-muted small">@item.Note</td>
                            <td class="text-end text-primary">@((item.Income > 0) ? item.Income.ToString("N0") : "")</td>
                            <td class="text-end text-danger">@((item.Expense > 0) ? item.Expense.ToString("N0") : "")</td>
                            <td>
                                <select class="form-select form-select-sm fw-bold @(item.Category=="미분류"?"border-danger text-danger":"text-success")" @bind="item.Category">
                                    @if(item.Category == "미분류") { <option value="미분류">미분류 ⚠️</option> }
                                    @if (item.Type == "수입") { @foreach(var c in IncomeCats) { <option value="@c">@c</option> } }
                                    else { @foreach(var c in ExpenseCats) { <option value="@c">@c</option> } }
                                </select>
                            </td>
                            <td>
                                <button class="btn btn-outline-danger btn-sm py-0" @onclick="() => _savedPreviewList.Remove(item)"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [CascadingParameter] public User? CurrentUser { get; set; }

    private string UserDepartment => CurrentUser?.Department ?? "";
    private DateTime? LastTransactionDate = null;

    private static List<LedgerEntry> _savedPreviewList = new();
    private static string _savedCurrentTab = "지출";

    private List<CategoryMapping> autoRules = new();
    private bool isLoading = false;
    private bool isSaving = false;
    private string errorMessage = "";

    private readonly string[] IncomeCats = new[] { "주일헌금", "찬조금", "이월금", "교회보조금", "은행이자", "회비수입", "환급금" };
    private readonly string[] ExpenseCats = new[] { "행사비", "공과비", "교육활동비", "여름성경학교", "운영비", "간식비", "부서관리비", "교사회의비", "훈련비" };

    private string searchUnclassified = "";
    private string searchPreview = "";
    private string batchSelectedCategory = "";
    private HashSet<LedgerEntry> selectedUnclassified = new();
    private LedgerEntry? draggedItem;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(UserDepartment)) return;
        if (UserDepartment == "관리자" || UserDepartment == "교육국") { errorMessage = "관리자 계정입니다. 부서 계정으로 로그인하세요."; return; }

        autoRules = await Accounting.GetMappingsAsync(UserDepartment);
        LastTransactionDate = await Accounting.GetLastTransactionDateAsync(UserDepartment);
    }

    private void ClearWorkData()
    {
        _savedPreviewList.Clear();
        _savedCurrentTab = "지출";
        selectedUnclassified.Clear();
        errorMessage = "";
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        isLoading = true; 
        _savedPreviewList.Clear(); 
        errorMessage = ""; 
        selectedUnclassified.Clear();
        
        try
        {
            System.Text.Encoding.RegisterProvider(System.Text.CodePagesEncodingProvider.Instance);
            
            // 🚀 버그 수정: using 문을 사용하여 메모리 스트림을 완전히 메모리에 올린 후 ExcelReader로 전달
            using var memoryStream = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(memoryStream);
            memoryStream.Position = 0; // 커서를 처음으로 되돌림

            using (var reader = ExcelReaderFactory.CreateReader(memoryStream))
            {
                var result = reader.AsDataSet();
                var table = result.Tables[0];
                int colDate = -1, colDesc = -1, colMemo = -1, colPerson = -1, colIn = -1, colOut = -1, dataStart = 0;
                
                for (int i = 0; i < Math.Min(table.Rows.Count, 15); i++)
                {
                    var row = table.Rows[i];
                    for (int c = 0; c < table.Columns.Count; c++)
                    {
                        string h = row[c]?.ToString()?.Trim() ?? "";
                        if (h == "거래일시" || h == "날짜") colDate = c;
                        else if (h == "적요") colDesc = c;
                        else if (h == "추가메모") colMemo = c;
                        else if (h.Contains("의뢰인") || h.Contains("수취인")) colPerson = c;
                        else if (h == "입금" || h.Contains("입금액")) colIn = c;
                        else if (h == "출금" || h.Contains("출금액")) colOut = c;
                    }
                    if (colDate >= 0 && colDesc >= 0) { dataStart = i + 1; break; }
                }
                
                if (colDate < 0) { colDate = 0; colDesc = 1; colMemo = 2; colPerson = 3; colIn = 4; colOut = 5; dataStart = 2; }
                string Cell(DataRow row, int idx) => idx >= 0 && idx < table.Columns.Count ? row[idx]?.ToString()?.Trim() ?? "" : "";

                for (int i = dataStart; i < table.Rows.Count; i++)
                {
                    var row = table.Rows[i];
                    if (!DateTime.TryParse(Cell(row, colDate), out DateTime date)) continue;

                    string desc = Cell(row, colDesc);
                    string memo = Cell(row, colMemo);
                    string person = Cell(row, colPerson);
                    decimal income = ParseDecimal(Cell(row, colIn));
                    decimal expense = ParseDecimal(Cell(row, colOut));
                    if (income == 0 && expense == 0) continue;

                    string type = income > 0 ? "수입" : "지출";
                    string cat = ClassifyAuto($"{desc} {person} {memo}", type);

                    _savedPreviewList.Add(new LedgerEntry { 
                        Date = date, Description = desc, Note = string.Join(" ", new[] { person, memo }.Where(s => !string.IsNullOrWhiteSpace(s))), 
                        Income = income, Expense = expense, Department = UserDepartment, 
                        Category = cat, Type = type, FiscalYear = date.Year, Quarter = GetQuarter(date), IsAudited = false 
                    });
                }
            }

            if (!_savedPreviewList.Any(x => x.Type == "지출" && x.Category == "미분류") && 
                 _savedPreviewList.Any(x => x.Type == "수입" && x.Category == "미분류"))
            {
                _savedCurrentTab = "수입";
            }
            else
            {
                _savedCurrentTab = "지출";
            }
        }
        catch (Exception ex) { errorMessage = $"오류: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private void ChangeTab(string targetTab)
    {
        _savedCurrentTab = targetTab;
        selectedUnclassified.Clear(); 
        batchSelectedCategory = "";
    }

    private List<LedgerEntry> GetFilteredUnclassified()
    {
        return _savedPreviewList.Where(x => x.Category == "미분류" && x.Type == _savedCurrentTab &&
            (string.IsNullOrEmpty(searchUnclassified) || 
             x.Description.Contains(searchUnclassified) || 
             x.Note.Contains(searchUnclassified))).ToList();
    }

    private IEnumerable<LedgerEntry> GetFilteredPreview()
    {
        if (string.IsNullOrEmpty(searchPreview)) return _savedPreviewList;
        return _savedPreviewList.Where(x => x.Description.Contains(searchPreview) || x.Note.Contains(searchPreview) || x.Category.Contains(searchPreview));
    }

    private void ToggleUnclassified(LedgerEntry item, ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false)) selectedUnclassified.Add(item);
        else selectedUnclassified.Remove(item);
    }
    
    private void ToggleRowClick(LedgerEntry item)
    {
        if (selectedUnclassified.Contains(item)) selectedUnclassified.Remove(item);
        else selectedUnclassified.Add(item);
    }

    private void SelectAllCurrentTab()
    {
        var currentList = GetFilteredUnclassified();
        if (selectedUnclassified.Count == currentList.Count) selectedUnclassified.Clear();
        else { foreach(var item in currentList) selectedUnclassified.Add(item); }
    }

    private void ApplyBatchToUnclassified()
    {
        if (string.IsNullOrEmpty(batchSelectedCategory) || !selectedUnclassified.Any()) return;
        foreach (var item in selectedUnclassified) { item.Category = batchSelectedCategory; }
        selectedUnclassified.Clear();
        batchSelectedCategory = "";
    }

    private void HandleDragStart(LedgerEntry item)
    {
        draggedItem = item;
        if (!selectedUnclassified.Contains(item))
        {
            selectedUnclassified.Clear();
            selectedUnclassified.Add(item);
        }
    }

    private void HandleDrop(string targetCategory)
    {
        if (draggedItem != null && selectedUnclassified.Any())
        {
            foreach (var item in selectedUnclassified) { item.Category = targetCategory; }
            selectedUnclassified.Clear();
            draggedItem = null;
        }
    }

    private string ClassifyAuto(string text, string type)
    {
        var matched = autoRules.FirstOrDefault(r => !string.IsNullOrEmpty(r.Keyword) && text.Contains(r.Keyword));
        if (matched != null) return matched.Category;

        if (type == "수입")
        {
            if (text.Contains("주정헌금") || text.Contains("주일헌금")) return "주일헌금";
            if (text.Contains("인천중앙교회")) return "교회보조금";
            if (text.Contains("이자")) return "은행이자";
        }
        else
        {
            if (text.Contains("다이소") || text.Contains("쿠팡")) return "행사비";
            if (text.Contains("씨유") || text.Contains("이마트")) return "간식비";
        }
        return "미분류";
    }

    private int GetQuarter(DateTime d) => d.Month switch { 12 or 1 or 2 => 1, 3 or 4 or 5 => 2, 6 or 7 or 8 => 3, _ => 4 };
    private decimal ParseDecimal(string? value) { if (string.IsNullOrWhiteSpace(value)) return 0; decimal.TryParse(value.Replace(",", ""), out decimal r); return r; }

    private async Task SaveToLedger()
    {
        if (!_savedPreviewList.Any()) return;
        if (_savedPreviewList.Any(x => x.Category == "미분류")) { await JSRuntime.InvokeVoidAsync("alert", "미분류 항목을 모두 처리해주세요!"); return; }

        if (await JSRuntime.InvokeAsync<bool>("confirm", $"{_savedPreviewList.Count}건을 저장하시겠습니까?"))
        {
            isSaving = true;
            try 
            { 
                await Accounting.AddTransactionsAsync(_savedPreviewList); 
                ClearWorkData();
                await JSRuntime.InvokeVoidAsync("alert", "저장 완료!"); 
                Nav.NavigateTo("/monthly"); 
            }
            catch (Exception ex) { errorMessage = $"저장 오류: {ex.Message}"; }
            finally { isSaving = false; }
        }
    }
}