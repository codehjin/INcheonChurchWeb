@page "/bank-import"
@using INcheonChurchWeb.Models
@using INcheonChurchWeb.Services
@using INcheonChurchWeb.Data
@using ExcelDataReader
@using System.Data
@using System.IO
@using Microsoft.AspNetCore.Components.Authorization
@inject AppDbContext DbContext
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container mt-4">
    <h3 class="fw-bold text-primary mb-4"><i class="bi bi-bank me-2"></i>은행 거래내역 가져오기</h3>

    @* 로그인한 사용자의 부서 표시 *@
    @if (!string.IsNullOrEmpty(UserDepartment))
    {
        <div class="alert alert-secondary">
            현재 <strong>'@UserDepartment'</strong> 장부로 기록됩니다.
            @if (UserDepartment == "유년부")
            {
                <span class="badge bg-success ms-2">자동 분류 적용됨 (시범운영)</span>
            }
            else
            {
                <span class="badge bg-warning text-dark ms-2">수동 분류 모드</span>
            }
        </div>
    }

    <div class="card p-4 shadow-sm bg-light border-0 mb-4">
        <div class="mb-3">
            <label class="form-label fw-bold">1. 은행 거래내역 파일 선택</label>
            <InputFile OnChange="LoadFiles" class="form-control" accept=".xls,.xlsx,.csv" />
            <div class="form-text text-muted">은행 엑셀 파일(.xls, .xlsx)을 업로드하세요.</div>
        </div>

        @* (로딩, 에러 메시지 부분은 기존과 동일) *@
        @if (isLoading)
        {
            <div class="alert alert-info">분석 중...</div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        @if (previewList != null && previewList.Any())
        {
            <div class="alert alert-success">총 <strong>@previewList.Count</strong> 건 불러옴</div>
        }
    </div>

    @* 미리보기 테이블 *@
    @if (previewList != null && previewList.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="fw-bold">미리보기</h5>
            <button class="btn btn-primary fw-bold" @onclick="SaveToLedger" disabled="@isSaving">
                @if (isSaving)
                {
                    <span>저장 중...</span>
                }
                else
                {

                    <span>장부에 저장하기</span>
                }
            </button>
        </div>

        <div class="table-responsive shadow-sm bg-white rounded" style="max-height: 500px; overflow-y: auto;">
            <table class="table table-hover align-middle mb-0 text-center sticky-top">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th>날짜</th>
                        <th class="text-start">적요</th>
                        <th class="text-start">비고</th>
                        <th>수입</th>
                        <th>지출</th>
                        <th>부서</th>
                        <th>분류</th> @* 분류 컬럼 추가 *@
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in previewList)
                    {
                        <tr>
                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                            <td class="text-start">@item.Description</td>
                            <td class="text-start text-muted small">@item.Note</td>
                            <td class="text-end text-primary">@((item.Income > 0) ? item.Income.ToString("N0") : "")</td>
                            <td class="text-end text-danger">@((item.Expense > 0) ? item.Expense.ToString("N0") : "")</td>
                            <td><span class="badge bg-secondary">@item.Department</span></td>
                            <td>
                                @* 자동 분류된 항목은 색상 표시 *@
                                @if (item.Category != "미분류")
                                {
                                    <span class="badge bg-success">@item.Category</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border">미분류</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }

    private string UserDepartment = ""; // 기본값 없음 (로그인 필수)
    private List<LedgerEntry> previewList = new();

    // DB에서 가져올 자동 분류 규칙 목록 (메모리에 캐싱)
    private List<CategoryMapping> autoRules = new();

    private bool isLoading = false;
    private bool isSaving = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        if (authenticationStateTask != null)
        {
            var authState = await authenticationStateTask;
            var user = authState.User;
            if (user.Identity != null && user.Identity.IsAuthenticated)
            {
                var deptClaim = user.FindFirst("Department");
                if (deptClaim != null)
                {
                    UserDepartment = deptClaim.Value;

                    // [중요] 로그인한 부서가 '교육국(Admin)'이면 장부 작성을 막거나 경고해야 함
                    if (UserDepartment == "교육국")
                    {
                        errorMessage = "관리자(교육국) 계정입니다. 장부를 작성하려면 각 부서 계정(유년부 등)으로 로그인하세요.";
                    }
                    else
                    {
                        // 해당 부서의 자동 분류 규칙만 DB에서 가져오기
                        // (유년부만 규칙이 들어있으므로 유년부만 가져와짐)
                        autoRules = DbContext.CategoryMappings
                            .Where(r => r.Department == UserDepartment)
                            .ToList();
                    }
                }
            }
        }
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        if (string.IsNullOrEmpty(UserDepartment) || UserDepartment == "교육국")
        {
            errorMessage = "올바른 부서 계정으로 로그인해주세요.";
            return;
        }

        isLoading = true;
        previewList.Clear();
        errorMessage = "";

        try
        {
            System.Text.Encoding.RegisterProvider(System.Text.CodePagesEncodingProvider.Instance);
            var file = e.File;

            using (var stream = new MemoryStream())
            {
                await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
                stream.Position = 0;

                using (var reader = ExcelReaderFactory.CreateReader(stream))
                {
                    var result = reader.AsDataSet();
                    var table = result.Tables[0];
                    bool headerFound = false;

                    for (int i = 0; i < table.Rows.Count; i++)
                    {
                        var row = table.Rows[i];

                        var colDate = row[0]?.ToString()?.Trim();
                        var colDesc = row[1]?.ToString()?.Trim(); // 적요 (예: 홍길동 주일헌금)
                        var colNote = row[3]?.ToString()?.Trim(); // 거래처
                        var colIn = row[4]?.ToString()?.Trim();
                        var colOut = row[5]?.ToString()?.Trim();

                        if (!headerFound)
                        {
                            if (colDate != null && colDate.Contains("거래일시")) headerFound = true;
                            continue;
                        }

                        if (string.IsNullOrEmpty(colDate) || !DateTime.TryParse(colDate, out DateTime dateValue)) continue;

                        try
                        {
                            decimal income = ParseDecimal(colIn);
                            decimal expense = ParseDecimal(colOut);

                            // [자동 분류 핵심 로직]
                            // 적요(Description)에 특정 키워드가 있는지 확인
                            string category = "미분류";
                            string cleanDesc = colDesc ?? "";

                            // 내 부서의 규칙 중에서 키워드가 포함된 게 있는지 찾기
                            var matchedRule = autoRules.FirstOrDefault(r => cleanDesc.Contains(r.Keyword));
                            if (matchedRule != null)
                            {
                                category = matchedRule.Category;
                            }

                            var entry = new LedgerEntry
                            {
                                Date = dateValue,
                                Description = cleanDesc,
                                Note = colNote ?? "",
                                Income = income,
                                Expense = expense,
                                Department = UserDepartment, // 내 부서 이름으로 저장
                                Category = category,         // 자동 분류된 카테고리
                                Type = income > 0 ? "수입" : "지출",
                                FiscalYear = dateValue.Year,
                                Quarter = (dateValue.Month - 1) / 3 + 1,
                                IsAudited = false
                            };

                            previewList.Add(entry);
                        }
                        catch { continue; }
                    }
                }
            }
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; }
    }

    private decimal ParseDecimal(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return 0;
        if (decimal.TryParse(value.Replace(",", ""), out decimal result)) return result;
        return 0;
    }

    private async Task SaveToLedger()
    {
        if (!previewList.Any()) return;
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"{previewList.Count}건을 저장하시겠습니까?"))
        {
            isSaving = true;
            DbContext.Transactions.AddRange(previewList);
            await DbContext.SaveChangesAsync();
            Nav.NavigateTo("/monthly");
        }
    }
}